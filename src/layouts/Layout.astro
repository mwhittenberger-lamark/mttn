---
import LeadModal from '../components/LeadModal.astro';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	robots?: string;
	structuredData?: string;
	ogType?: string;
	ogSiteName?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogUrl?: string;
	ogImage?: string;
	ogImageAlt?: string;
	twitterCard?: string;
	twitterTitle?: string;
	twitterDescription?: string;
	twitterImage?: string;
}

const {
	title = 'Mike the Tech Ninja | Practical Digital Growth for Triangle Small Businesses',
	description = 'Local digital partner for small businesses across Raleigh, Cary, Durham, Chapel Hill, and the broader Triangle.',
	canonical,
	robots,
	structuredData,
	ogType,
	ogSiteName,
	ogTitle,
	ogDescription,
	ogUrl,
	ogImage,
	ogImageAlt,
	twitterCard,
	twitterTitle,
	twitterDescription,
	twitterImage,
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preload" href="/fonts/source-sans-3-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/sora-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/styles/site.css" as="style" />
		<link rel="stylesheet" href="/styles/site.css" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{canonical && <link rel="canonical" href={canonical} />}
		{robots && <meta name="robots" content={robots} />}
		{structuredData && <script type="application/ld+json" set:html={structuredData}></script>}
		{ogType && <meta property="og:type" content={ogType} />}
		{ogSiteName && <meta property="og:site_name" content={ogSiteName} />}
		{ogTitle && <meta property="og:title" content={ogTitle} />}
		{ogDescription && <meta property="og:description" content={ogDescription} />}
		{ogUrl && <meta property="og:url" content={ogUrl} />}
		{ogImage && <meta property="og:image" content={ogImage} />}
		{ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
		{twitterCard && <meta name="twitter:card" content={twitterCard} />}
		{twitterTitle && <meta name="twitter:title" content={twitterTitle} />}
		{twitterDescription && <meta name="twitter:description" content={twitterDescription} />}
		{twitterImage && <meta name="twitter:image" content={twitterImage} />}
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<LeadModal />
		<script src="/scripts/lead-modal.js" defer></script>
	</body>
</html>

<style is:global>
	@font-face {
		font-family: 'Source Sans 3';
		src: url('/fonts/source-sans-3-latin.woff2') format('woff2');
		font-style: normal;
		font-weight: 400 700;
		font-display: swap;
	}

	@font-face {
		font-family: 'Sora';
		src: url('/fonts/sora-latin.woff2') format('woff2');
		font-style: normal;
		font-weight: 400 700;
		font-display: swap;
	}

	:root {
		color-scheme: light;
		font-family: 'Source Sans 3', 'Segoe UI', Helvetica, Arial, sans-serif;
		--color-black: #0b0b0b;
		--color-white: #ffffff;
		--color-soft: #f5f5f3;
		--color-gray: #737373;
		--color-blue: #2563eb;
		--color-sky: #4da3d9;
		--color-green: #a3e635;
		--color-border: rgba(11, 11, 11, 0.1);
		--color-panel: rgba(255, 255, 255, 0.86);
		--shadow-soft: 0 18px 50px rgba(11, 11, 11, 0.07);
		background:
			radial-gradient(circle at 15% 0%, rgba(37, 99, 235, 0.08), transparent 24%),
			radial-gradient(circle at 100% 10%, rgba(163, 230, 53, 0.08), transparent 20%),
			linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
		color: var(--color-black);
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		background: var(--color-white);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	button,
	input,
	select,
	textarea {
		font: inherit;
	}

	h1,
	h2,
	h3,
	h4 {
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
	}

	::selection {
		background: rgba(37, 99, 235, 0.18);
	}

	.page {
		position: relative;
		min-height: 100vh;
		background: var(--color-white);
	}

	.progress {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		height: 4px;
		z-index: 80;
	}

	.progress-bar {
		width: 100%;
		height: 100%;
		transform-origin: left center;
		transform: scaleX(0);
		background: linear-gradient(90deg, var(--color-blue), var(--color-sky), var(--color-green));
	}

	.container {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.narrow-center {
		max-width: 980px;
		margin: 0 auto;
		text-align: center;
	}

	.site-nav {
		position: sticky;
		top: 0;
		z-index: 60;
		border-bottom: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(14px);
	}

	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		min-height: 56px;
		position: relative;
	}

	.brand,
	.footer-brand {
		display: flex;
		align-items: center;
		gap: 10px;
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.95rem;
		font-weight: 600;
	}

	.brand img,
	.footer-brand img {
		width: 32px;
		height: 32px;
		object-fit: contain;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 24px;
	}

	.nav-links .nav-links__cta {
		display: none;
		color: var(--color-white);
	}

	.nav-links .nav-links__cta::after {
		display: none;
	}

	.nav-links .nav-links__cta:hover {
		color: var(--color-white);
	}

	.nav-mobile-consult {
		display: none;
		color: var(--color-white);
		white-space: nowrap;
	}

	.nav-links a {
		position: relative;
		font-size: 0.8rem;
		color: var(--color-gray);
		transition: color 0.2s ease;
	}

	.nav-links a::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -4px;
		width: 0;
		height: 2px;
		background: var(--color-blue);
		transition: width 0.2s ease;
	}

	.nav-links a:hover {
		color: var(--color-black);
	}

	.nav-links a:hover::after {
		width: 100%;
	}

	.nav-toggle {
		display: none;
		position: relative;
		width: 46px;
		height: 46px;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.92);
		box-shadow: 0 8px 20px rgba(11, 11, 11, 0.06);
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
	}

	.nav-toggle:hover {
		transform: translateY(-1px);
		box-shadow: 0 12px 24px rgba(11, 11, 11, 0.1);
	}

	.nav-toggle span {
		position: absolute;
		width: 20px;
		height: 2px;
		border-radius: 999px;
		background: var(--color-black);
		transition: transform 0.24s ease, opacity 0.2s ease, top 0.24s ease;
	}

	.nav-toggle span:nth-child(1) {
		top: 16px;
	}

	.nav-toggle span:nth-child(2) {
		top: 22px;
	}

	.nav-toggle span:nth-child(3) {
		top: 28px;
	}

	.site-nav.is-open .nav-toggle span:nth-child(1) {
		top: 22px;
		transform: rotate(45deg);
	}

	.site-nav.is-open .nav-toggle span:nth-child(2) {
		opacity: 0;
	}

	.site-nav.is-open .nav-toggle span:nth-child(3) {
		top: 22px;
		transform: rotate(-45deg);
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		min-height: 44px;
		padding: 0 18px;
		border-radius: 10px;
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.88rem;
		font-weight: 600;
		transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button.small {
		min-height: 38px;
		padding: 0 16px;
		font-size: 0.78rem;
	}

	.button.primary {
		color: var(--color-white);
		background: linear-gradient(90deg, var(--color-blue), var(--color-sky));
		box-shadow: 0 12px 28px rgba(37, 99, 235, 0.22);
	}

	.button.secondary {
		border: 1px solid var(--color-border);
		background: var(--color-white);
		color: var(--color-black);
		box-shadow: 0 3px 10px rgba(11, 11, 11, 0.04);
	}

	.hero {
		position: relative;
		overflow: hidden;
		padding: 48px 0 40px;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(135deg, rgba(37, 99, 235, 0.05), transparent 50%, rgba(77, 163, 217, 0.05)),
			var(--color-white);
	}

	.floating-orb {
		position: absolute;
		width: 180px;
		height: 180px;
		border-radius: 50%;
		filter: blur(40px);
		opacity: 0.55;
	}

	.orb-left {
		top: 64px;
		left: 48px;
		background: rgba(37, 99, 235, 0.12);
	}

	.orb-right {
		right: 80px;
		bottom: 80px;
		background: rgba(163, 230, 53, 0.12);
	}

	.hero-grid {
		position: relative;
		display: grid;
		gap: 32px;
		align-items: center;
		grid-template-columns: minmax(0, 1fr) minmax(0, 560px);
	}

	.eyebrow-chip {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 12px;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.9);
		font-size: 0.72rem;
	}

	.inline-icon {
		width: 16px;
		height: 16px;
		display: block;
	}

	.icon-blue {
		filter: brightness(0) saturate(100%) invert(34%) sepia(95%) saturate(1682%) hue-rotate(213deg) brightness(94%) contrast(96%);
	}

	.icon-red {
		filter: brightness(0) saturate(100%) invert(18%) sepia(80%) saturate(2977%) hue-rotate(336deg) brightness(86%) contrast(95%);
	}

	.icon-dark {
		filter: brightness(0) saturate(100%) invert(4%) sepia(3%) saturate(4860%) hue-rotate(329deg) brightness(95%) contrast(98%);
	}

	h1,
	h2,
	h3 {
		margin: 0;
		color: var(--color-black);
	}

	h1 {
		margin-top: 14px;
		font-size: clamp(2.6rem, 5vw, 4.2rem);
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.04em;
	}

	h1 span {
		color: var(--color-blue);
	}

	h2 {
		font-size: clamp(1.9rem, 3.8vw, 3rem);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.04em;
	}

	h3 {
		font-size: 1rem;
		font-weight: 700;
	}

	p {
		margin: 0;
		font-size: 1rem;
		line-height: 1.65;
		color: #4b5563;
	}

	.lede {
		max-width: 680px;
		margin-top: 18px;
		font-size: 1rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 22px;
	}

	.hero-visual {
		position: relative;
		min-height: 430px;
		display: none;
	}

	.hero-logo-wrap {
		position: absolute;
		z-index: 1;
		inset: 80px 112px 88px 112px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero-logo-wrap img {
		width: min(240px, 100%);
		height: auto;
		filter: drop-shadow(0 18px 30px rgba(11, 11, 11, 0.1));
	}

	.hero-card {
		position: absolute;
		z-index: 3;
		padding: 14px;
		border: 1px solid var(--color-border);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.82);
		box-shadow: 0 14px 30px rgba(11, 11, 11, 0.09);
		backdrop-filter: blur(12px);
	}

	.hero-card-services {
		top: 30px;
		left: 12px;
		width: 150px;
	}

	.hero-card-users {
		top: 0;
		right: 12px;
		width: 180px;
	}

	.hero-card-growth {
		left: 24px;
		bottom: 10px;
		width: 170px;
	}

	.hero-card-local {
		right: 16px;
		bottom: 48px;
		width: 160px;
	}

	.mini-row {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 8px;
	}

	.mini-label {
		font-size: 0.65rem;
		font-weight: 700;
		color: var(--color-black);
	}

	.mini-icon {
		width: 28px;
		height: 28px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 10px;
	}

	.mini-icon.blue {
		background: linear-gradient(135deg, rgba(37, 99, 235, 0.2), rgba(77, 163, 217, 0.15));
	}

	.mini-icon.green {
		background: linear-gradient(135deg, rgba(163, 230, 53, 0.24), rgba(163, 230, 53, 0.14));
	}

	.hero-card p,
	.hero-card li {
		font-size: 1rem;
		line-height: 1.45;
	}

	.hero-card strong {
		display: block;
		margin: 6px 0;
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 1.5rem;
		line-height: 1;
		color: var(--color-black);
	}

	.hero-card ul {
		margin: 8px 0 0;
		padding-left: 14px;
	}

	.meter {
		height: 4px;
		margin-top: 8px;
		border-radius: 999px;
		background: rgba(37, 99, 235, 0.14);
		overflow: hidden;
	}

	.meter div {
		width: 80%;
		height: 100%;
		background: var(--color-blue);
	}

	@media (min-width: 768px) {
		.hero-visual {
			display: block;
		}
	}

	@media (max-width: 1024px) and (min-width: 768px) {
		.hero-grid {
			gap: 24px;
			grid-template-columns: minmax(0, 1fr) minmax(320px, 420px);
		}

		.hero-visual {
			min-height: 360px;
		}

		.hero-logo-wrap {
			inset: 70px 88px 82px 88px;
		}

		.hero-logo-wrap img {
			width: min(190px, 100%);
		}

		.hero-card {
			padding: 12px;
			border-radius: 16px;
		}

		.hero-card-services {
			top: 24px;
			left: 8px;
			width: 132px;
		}

		.hero-card-users {
			top: 4px;
			right: 8px;
			width: 156px;
		}

		.hero-card-growth {
			left: 16px;
			bottom: 12px;
			width: 148px;
		}

		.hero-card-local {
			right: 10px;
			bottom: 42px;
			width: 144px;
		}

		.hero-card p,
		.hero-card li {
			font-size: 0.92rem;
			line-height: 1.4;
		}

		.hero-card strong {
			font-size: 1.3rem;
		}
	}

	@media (max-width: 780px) {
		.nav-inner {
			padding: 10px 0;
			gap: 20px;
		}

		.nav-links {
			position: absolute;
			top: calc(100% + 10px);
			left: 0;
			right: 0;
			z-index: 70;
			display: flex;
			flex-direction: column;
			align-items: stretch;
			gap: 0;
			padding: 12px;
			border: 1px solid var(--color-border);
			border-radius: 20px;
			background: rgba(255, 255, 255, 0.97);
			box-shadow: 0 24px 50px rgba(11, 11, 11, 0.12);
			backdrop-filter: blur(16px);
			opacity: 0;
			transform: translateY(-10px) scale(0.98);
			transform-origin: top center;
			pointer-events: none;
			transition: opacity 0.22s ease, transform 0.22s ease;
		}

		.site-nav.is-open .nav-links {
			opacity: 1;
			transform: translateY(0) scale(1);
			pointer-events: auto;
		}

		.nav-links a {
			padding: 14px 12px;
			font-size: 0.98rem;
			border-radius: 12px;
			transform: translateY(8px);
			opacity: 0;
			transition: opacity 0.2s ease, transform 0.2s ease, background 0.2s ease;
		}

		.site-nav.is-open .nav-links a {
			transform: translateY(0);
			opacity: 1;
		}

		.nav-links a::after {
			display: none;
		}

		.nav-links a:hover {
			background: rgba(37, 99, 235, 0.06);
		}

		.nav-links .nav-links__cta {
			display: inline-flex;
			margin-top: 8px;
			width: 100%;
		}

		.nav-toggle {
			display: inline-flex;
		}

		.nav-mobile-consult {
			display: inline-flex;
			margin-left: auto;
			margin-right: 0;
		}

		.hero-grid {
			grid-template-columns: 1fr;
		}

		.nav-inner > .button:not(.nav-mobile-consult) {
			display: none;
		}
	}

	@media (max-width: 700px) {
		.container {
			padding: 0 16px;
		}

		.brand {
			margin-top: 10px;
		}

		.hero {
			padding-top: 36px;
		}

		.hero-actions .button {
			width: 100%;
		}
	}
</style>
