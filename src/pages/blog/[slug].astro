---
import Layout from '../../layouts/Layout.astro'
import SiteHeader from '../../components/SiteHeader.astro'
import SiteFooter from '../../components/SiteFooter.astro'
import PortableText from '../../components/PortableText.astro'
import {urlFor} from '../../lib/sanity-image'
import {sanityClient} from 'sanity:client'

const authorProfile = {
	name: 'Mike Whittenberger',
	role: 'Digital strategist, web developer, AI builder, and marketing consultant',
	bio:
		'Mike helps Triangle small businesses turn limited budgets into smarter websites, more useful AI, cleaner follow-up, and clearer digital strategy without big-agency overhead.',
	imageSrc: '/mike-whittenberger-headshot.jpg',
	linkedinHref: 'https://www.linkedin.com/in/mike-ninja-413545411',
	linkedinLabel: 'Connect with Mike on LinkedIn',
}

const businessSidebar = {
	title: 'About Mike the Tech Ninja',
	copy:
		'Mike the Tech Ninja helps Triangle small businesses build better websites, use practical AI, run smarter marketing, and create digital systems that actually support growth.',
	highlights: [
		'Local to the Triangle, remote-friendly everywhere else',
		'Senior-level help without a bloated agency retainer',
		'Websites, AI, SEO, paid media, email, CRO, and strategy',
	],
}

const tuneUpOffer = {
	title: 'Triangle Digital Tune-Up',
	price: 'Starting at $750',
	copy:
		'A focused audit of your website, marketing, SEO, tracking, and AI opportunities with a prioritized action plan.',
	ctaLabel: 'Request a Digital Tune-Up',
	ctaHref: '/#packages',
}

export async function getStaticPaths() {
	const slugs = await sanityClient.fetch<{slug: {current: string}}[]>(
		`*[_type == "post" && defined(slug.current)]{slug}`
	)

	return slugs.map((entry) => ({
		params: {
			slug: entry.slug.current,
		},
	}))
}

const {slug} = Astro.params

type BlogPost = {
	title: string
	slug: {current: string}
	excerpt: string
	publishedAt: string
	body: any[]
	schemaMarkup?: string
	tags?: string[]
	featuredImage?: {
		alt?: string
		asset?: unknown
	}
	seo?: {
		metaTitle?: string
		metaDescription?: string
		canonicalUrl?: string
		noIndex?: boolean
		ogTitle?: string
		ogDescription?: string
		ogImage?: {
			alt?: string
			asset?: unknown
		}
		twitterTitle?: string
		twitterDescription?: string
		twitterImage?: {
			alt?: string
			asset?: unknown
		}
	}
}

type RelatedPost = {
	title: string
	slug: {current: string}
	excerpt: string
	publishedAt: string
	tags?: string[]
}

const post = slug
	? await sanityClient.fetch<BlogPost | null>(
			`*[_type == "post" && slug.current == $slug][0]{
				title,
				slug,
				excerpt,
				publishedAt,
				body,
				schemaMarkup,
				tags,
				seo{
					metaTitle,
					metaDescription,
					canonicalUrl,
					noIndex,
					ogTitle,
					ogDescription,
					ogImage{
						alt,
						asset
					},
					twitterTitle,
					twitterDescription,
					twitterImage{
						alt,
						asset
					}
				},
				featuredImage{
					alt,
					asset
				}
			}`,
			{slug}
		)
	: null

if (!post) {
	Astro.response.status = 404
}

const formatDate = (value: string) =>
	new Date(value).toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	})

const flattenPortableText = (value: any[] = []) =>
	value
		.flatMap((block) => {
			if (!block || typeof block !== 'object') return []
			if (block._type !== 'block' || !Array.isArray(block.children)) return []
			return block.children
				.map((child: {text?: string}) => child?.text?.trim() || '')
				.filter(Boolean)
		})
		.join(' ')

const readingTimeMinutes = post
	? Math.max(1, Math.ceil(flattenPortableText(post.body).split(/\s+/).filter(Boolean).length / 225))
	: 1

const relatedCandidates = post
	? await sanityClient.fetch<RelatedPost[]>(
			`*[_type == "post" && defined(slug.current) && slug.current != $slug] | order(publishedAt desc){
				title,
				slug,
				excerpt,
				publishedAt,
				tags
			}`,
			{slug}
		)
	: []

const relatedPosts = relatedCandidates
	.map((entry) => {
		const overlap = entry.tags?.filter((tag) => post?.tags?.includes(tag)).length ?? 0
		return {
			...entry,
			overlap,
		}
	})
	.sort((left, right) => {
		if (right.overlap !== left.overlap) return right.overlap - left.overlap
		return new Date(right.publishedAt).getTime() - new Date(left.publishedAt).getTime()
	})
	.slice(0, 3)

const heroImageUrl =
	post?.featuredImage?.asset && urlFor(post.featuredImage).width(1400).fit('max').auto('format').url()

const canonicalUrl = post?.seo?.canonicalUrl?.trim() || (post ? `https://whoisthetechninja.com/blog/${post.slug.current}/` : 'https://whoisthetechninja.com/blog/')
const pageTitle = post ? post.seo?.metaTitle?.trim() || `${post.title} | Mike the Tech Ninja Blog` : 'Post Not Found | Mike the Tech Ninja'
const pageDescription = post?.seo?.metaDescription?.trim() || post?.excerpt || 'The requested blog post could not be found.'
const ogImageUrl =
	post?.seo?.ogImage?.asset && urlFor(post.seo.ogImage).width(1200).height(630).fit('crop').auto('format').url()
const twitterImageUrl =
	post?.seo?.twitterImage?.asset &&
	urlFor(post.seo.twitterImage).width(1200).height(675).fit('crop').auto('format').url()
const finalOgImage = ogImageUrl || heroImageUrl || undefined
const finalTwitterImage = twitterImageUrl || finalOgImage

const fallbackStructuredData = post
	? JSON.stringify(
			{
				'@context': 'https://schema.org',
				'@type': 'BlogPosting',
				'@id': `${canonicalUrl}#blogposting`,
				mainEntityOfPage: canonicalUrl,
				headline: post.title,
				description: post.excerpt,
				datePublished: post.publishedAt,
				dateModified: post.publishedAt,
				author: {
					'@type': 'Person',
					name: 'Mike Whittenberger',
				},
				publisher: {
					'@type': 'Organization',
					name: 'Mike the Tech Ninja',
					logo: {
						'@type': 'ImageObject',
						url: 'https://whoisthetechninja.com/images/mike-the-tech-ninja-logo.png',
					},
				},
				image: heroImageUrl ? [heroImageUrl] : undefined,
				keywords: post.tags?.join(', '),
			},
			null,
			2
		)
	: undefined

const postStructuredData = post?.schemaMarkup?.trim() || fallbackStructuredData
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical={canonicalUrl}
	robots={post?.seo?.noIndex ? 'noindex, follow, max-image-preview:large' : 'index, follow, max-image-preview:large'}
	structuredData={postStructuredData}
	ogType="article"
	ogSiteName="Mike the Tech Ninja"
	ogTitle={post?.seo?.ogTitle?.trim() || post?.seo?.metaTitle?.trim() || post?.title}
	ogDescription={post?.seo?.ogDescription?.trim() || post?.seo?.metaDescription?.trim() || post?.excerpt}
	ogUrl={post ? canonicalUrl : undefined}
	ogImage={finalOgImage}
	ogImageAlt={post?.seo?.ogImage?.alt || post?.featuredImage?.alt || post?.title}
	twitterCard={finalTwitterImage ? 'summary_large_image' : 'summary'}
	twitterTitle={post?.seo?.twitterTitle?.trim() || post?.seo?.ogTitle?.trim() || post?.seo?.metaTitle?.trim() || post?.title}
	twitterDescription={post?.seo?.twitterDescription?.trim() || post?.seo?.ogDescription?.trim() || post?.seo?.metaDescription?.trim() || post?.excerpt}
	twitterImage={finalTwitterImage}
>
	<div class="page">
		<SiteHeader />
		<main class="post-page">
			<div class="container">
				{post ? (
					<div class="post-layout">
						<article class="post">
							<a class="post__back" href="/blog/">Back to blog</a>
							<header class="post__header">
								<div class="post__meta-row">
									<p class="post__meta">{formatDate(post.publishedAt)}</p>
									<p class="post__meta">{readingTimeMinutes} min read</p>
									<p class="post__meta">By {authorProfile.name}</p>
								</div>
								<h1>{post.title}</h1>
								<p class="post__excerpt">{post.excerpt}</p>
								{post.tags && post.tags.length > 0 && (
									<div class="post__tags">
										{post.tags.map((tag) => <span>{tag}</span>)}
									</div>
								)}
							</header>

							{heroImageUrl && (
								<img
									class="post__hero"
									src={heroImageUrl}
									alt={post.featuredImage?.alt ?? post.title}
									loading="eager"
								/>
							)}

							<div class="post__body prose">
								<PortableText value={post.body} />
							</div>

							<section class="author-box" aria-labelledby="author-box-title">
								<img
									class="author-box__image"
									src={authorProfile.imageSrc}
									alt="Mike Whittenberger, founder of Mike the Tech Ninja"
									loading="lazy"
								/>
								<div class="author-box__copy">
									<p class="author-box__eyebrow">About the author</p>
									<h2 id="author-box-title">{authorProfile.name}</h2>
									<p class="author-box__role">{authorProfile.role}</p>
									<p>{authorProfile.bio}</p>
									<a
										class="button secondary small"
										href={authorProfile.linkedinHref}
										target="_blank"
										rel="noreferrer"
									>
										{authorProfile.linkedinLabel}
									</a>
								</div>
							</section>
						</article>

						<aside class="post-sidebar" aria-label="Article sidebar">
							<section class="sidebar-card">
								<p class="sidebar-card__eyebrow">Business snapshot</p>
								<h2>{businessSidebar.title}</h2>
								<p>{businessSidebar.copy}</p>
								<ul class="sidebar-list">
									{businessSidebar.highlights.map((item) => <li>{item}</li>)}
								</ul>
							</section>

							<section class="sidebar-card sidebar-card--offer">
								<p class="sidebar-card__eyebrow">Featured offer</p>
								<h2>{tuneUpOffer.title}</h2>
								<p>{tuneUpOffer.copy}</p>
								<div class="sidebar-offer__price">{tuneUpOffer.price}</div>
								<a class="button primary small" href={tuneUpOffer.ctaHref}>{tuneUpOffer.ctaLabel}</a>
							</section>

							{relatedPosts.length > 0 && (
								<section class="sidebar-card">
									<p class="sidebar-card__eyebrow">Related posts</p>
									<h2>Keep reading</h2>
									<div class="related-posts">
										{relatedPosts.map((relatedPost) => (
											<article class="related-post">
												<p class="related-post__meta">{formatDate(relatedPost.publishedAt)}</p>
												<h3>
													<a href={`/blog/${relatedPost.slug.current}/`}>{relatedPost.title}</a>
												</h3>
												<p>{relatedPost.excerpt}</p>
											</article>
										))}
									</div>
								</section>
							)}
						</aside>
					</div>
				) : (
					<section class="post-missing">
						<h1>Post not found.</h1>
						<p>The requested article does not exist or is not published yet.</p>
						<a class="post__back" href="/blog/">Return to the blog</a>
					</section>
				)}
			</div>
		</main>
		<SiteFooter />
	</div>
</Layout>

<script src="/scripts/site-nav.js" defer></script>

<style>
	.post-page {
		padding: 56px 0 80px;
		background:
			radial-gradient(circle at 15% 0%, rgba(37, 99, 235, 0.08), transparent 24%),
			radial-gradient(circle at 100% 10%, rgba(163, 230, 53, 0.08), transparent 20%),
			linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
	}

	.post {
		min-width: 0;
	}

	.post-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 320px;
		gap: 32px;
		align-items: start;
	}

	.post__back {
		display: inline-flex;
		margin-bottom: 28px;
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--color-blue);
	}

	.post__header {
		display: grid;
		gap: 16px;
	}

	.post__meta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.post__meta {
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-gray);
	}

	.post__meta:not(:last-child)::after {
		content: '•';
		margin-left: 10px;
	}

	.post__header h1 {
		font-size: clamp(2.5rem, 5vw, 4.6rem);
		line-height: 1.02;
	}

	.post__excerpt {
		max-width: 60ch;
		font-size: 1.12rem;
	}

	.post__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.post__tags span {
		padding: 6px 10px;
		border-radius: 999px;
		background: rgba(37, 99, 235, 0.08);
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-black);
	}

	.post__hero {
		width: 100%;
		margin-top: 28px;
		border-radius: 28px;
		height: auto;
		display: block;
		box-shadow: 0 24px 60px rgba(11, 11, 11, 0.12);
	}

	.post__body {
		margin-top: 36px;
		padding: 32px;
		border: 1px solid var(--color-border);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 18px 42px rgba(11, 11, 11, 0.06);
	}

	.author-box,
	.sidebar-card {
		border: 1px solid var(--color-border);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.92);
		box-shadow: 0 18px 42px rgba(11, 11, 11, 0.06);
	}

	.author-box {
		display: grid;
		grid-template-columns: 120px minmax(0, 1fr);
		gap: 22px;
		margin-top: 28px;
		padding: 24px;
	}

	.author-box__image {
		width: 120px;
		height: 120px;
		padding: 16px;
		border-radius: 24px;
		background: linear-gradient(180deg, #ffffff, #eef3ff);
		object-fit: contain;
	}

	.author-box__copy {
		display: grid;
		gap: 10px;
	}

	.author-box__eyebrow,
	.sidebar-card__eyebrow {
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-blue);
	}

	.author-box__role {
		font-weight: 600;
		color: var(--color-black);
	}

	.post-sidebar {
		position: sticky;
		top: 108px;
		display: grid;
		gap: 18px;
	}

	.sidebar-card {
		padding: 22px;
	}

	.sidebar-card h2 {
		margin-top: 10px;
		font-size: 1.35rem;
		line-height: 1.15;
	}

	.sidebar-card p + p,
	.sidebar-card p + ul,
	.sidebar-card p + div {
		margin-top: 14px;
	}

	.sidebar-list {
		display: grid;
		gap: 10px;
		padding-left: 18px;
	}

	.sidebar-offer__price {
		margin: 16px 0 18px;
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 1.45rem;
		font-weight: 700;
		color: var(--color-blue);
	}

	.related-posts {
		display: grid;
		gap: 16px;
		margin-top: 16px;
	}

	.related-post:not(:last-child) {
		padding-bottom: 16px;
		border-bottom: 1px solid rgba(11, 11, 11, 0.08);
	}

	.related-post__meta {
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-gray);
	}

	.related-post h3 {
		margin-top: 8px;
		font-size: 1.02rem;
		line-height: 1.2;
	}

	.related-post h3 a:hover {
		color: var(--color-blue);
	}

	.related-post p:last-child {
		margin-top: 8px;
		font-size: 0.98rem;
	}

	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4) {
		margin-top: 1.8em;
		margin-bottom: 0.5em;
	}

	.prose :global(p),
	.prose :global(ul),
	.prose :global(ol) {
		margin: 1em 0;
	}

	.prose :global(ul),
	.prose :global(ol) {
		padding-left: 1.4rem;
	}

	.prose :global(a) {
		color: var(--color-blue);
		text-decoration: underline;
	}

	.prose :global(blockquote) {
		margin: 1.5em 0;
		padding-left: 1rem;
		border-left: 3px solid rgba(37, 99, 235, 0.24);
		color: var(--color-black);
	}

	.prose :global(img) {
		width: 100%;
		height: auto;
		margin: 1.5em 0;
		border-radius: 18px;
	}

	.post-missing {
		max-width: 760px;
		margin: 0 auto;
		padding: 40px 32px;
		border: 1px solid var(--color-border);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.88);
		text-align: center;
	}

	@media (max-width: 700px) {
		.post-page {
			padding-top: 40px;
		}

		.post-layout {
			grid-template-columns: 1fr;
		}

		.post__meta:not(:last-child)::after {
			display: none;
		}

		.author-box {
			grid-template-columns: 1fr;
		}

		.author-box__image {
			width: 96px;
			height: 96px;
		}

		.post-sidebar {
			position: static;
		}

		.post__body {
			padding: 24px 18px;
		}
	}
</style>
