---
import Layout from '../../layouts/Layout.astro'
import PortableText from '../../components/PortableText.astro'
import {urlFor} from '../../lib/sanity-image'
import {sanityClient} from 'sanity:client'

export async function getStaticPaths() {
	const slugs = await sanityClient.fetch<{slug: {current: string}}[]>(
		`*[_type == "post" && defined(slug.current)]{slug}`
	)

	return slugs.map((entry) => ({
		params: {
			slug: entry.slug.current,
		},
	}))
}

const {slug} = Astro.params

type BlogPost = {
	title: string
	slug: {current: string}
	excerpt: string
	publishedAt: string
	body: any[]
	schemaMarkup?: string
	tags?: string[]
	featuredImage?: {
		alt?: string
		asset?: unknown
	}
	seo?: {
		metaTitle?: string
		metaDescription?: string
		canonicalUrl?: string
		noIndex?: boolean
		ogTitle?: string
		ogDescription?: string
		ogImage?: {
			alt?: string
			asset?: unknown
		}
		twitterTitle?: string
		twitterDescription?: string
		twitterImage?: {
			alt?: string
			asset?: unknown
		}
	}
}

const post = slug
	? await sanityClient.fetch<BlogPost | null>(
			`*[_type == "post" && slug.current == $slug][0]{
				title,
				slug,
				excerpt,
				publishedAt,
				body,
				schemaMarkup,
				tags,
				seo{
					metaTitle,
					metaDescription,
					canonicalUrl,
					noIndex,
					ogTitle,
					ogDescription,
					ogImage{
						alt,
						asset
					},
					twitterTitle,
					twitterDescription,
					twitterImage{
						alt,
						asset
					}
				},
				featuredImage{
					alt,
					asset
				}
			}`,
			{slug}
		)
	: null

if (!post) {
	Astro.response.status = 404
}

const formatDate = (value: string) =>
	new Date(value).toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	})

const heroImageUrl =
	post?.featuredImage?.asset && urlFor(post.featuredImage).width(1400).height(780).fit('crop').auto('format').url()

const canonicalUrl = post?.seo?.canonicalUrl?.trim() || (post ? `https://whoisthetechninja.com/blog/${post.slug.current}/` : 'https://whoisthetechninja.com/blog/')
const pageTitle = post ? post.seo?.metaTitle?.trim() || `${post.title} | Mike the Tech Ninja Blog` : 'Post Not Found | Mike the Tech Ninja'
const pageDescription = post?.seo?.metaDescription?.trim() || post?.excerpt || 'The requested blog post could not be found.'
const ogImageUrl =
	post?.seo?.ogImage?.asset && urlFor(post.seo.ogImage).width(1200).height(630).fit('crop').auto('format').url()
const twitterImageUrl =
	post?.seo?.twitterImage?.asset &&
	urlFor(post.seo.twitterImage).width(1200).height(675).fit('crop').auto('format').url()
const finalOgImage = ogImageUrl || heroImageUrl || undefined
const finalTwitterImage = twitterImageUrl || finalOgImage

const fallbackStructuredData = post
	? JSON.stringify(
			{
				'@context': 'https://schema.org',
				'@type': 'BlogPosting',
				'@id': `${canonicalUrl}#blogposting`,
				mainEntityOfPage: canonicalUrl,
				headline: post.title,
				description: post.excerpt,
				datePublished: post.publishedAt,
				dateModified: post.publishedAt,
				author: {
					'@type': 'Person',
					name: 'Mike Whittenberger',
				},
				publisher: {
					'@type': 'Organization',
					name: 'Mike the Tech Ninja',
					logo: {
						'@type': 'ImageObject',
						url: 'https://whoisthetechninja.com/images/mike-the-tech-ninja-logo.png',
					},
				},
				image: heroImageUrl ? [heroImageUrl] : undefined,
				keywords: post.tags?.join(', '),
			},
			null,
			2
		)
	: undefined

const postStructuredData = post?.schemaMarkup?.trim() || fallbackStructuredData
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical={canonicalUrl}
	robots={post?.seo?.noIndex ? 'noindex, follow, max-image-preview:large' : 'index, follow, max-image-preview:large'}
	structuredData={postStructuredData}
	ogType="article"
	ogSiteName="Mike the Tech Ninja"
	ogTitle={post?.seo?.ogTitle?.trim() || post?.seo?.metaTitle?.trim() || post?.title}
	ogDescription={post?.seo?.ogDescription?.trim() || post?.seo?.metaDescription?.trim() || post?.excerpt}
	ogUrl={post ? canonicalUrl : undefined}
	ogImage={finalOgImage}
	ogImageAlt={post?.seo?.ogImage?.alt || post?.featuredImage?.alt || post?.title}
	twitterCard={finalTwitterImage ? 'summary_large_image' : 'summary'}
	twitterTitle={post?.seo?.twitterTitle?.trim() || post?.seo?.ogTitle?.trim() || post?.seo?.metaTitle?.trim() || post?.title}
	twitterDescription={post?.seo?.twitterDescription?.trim() || post?.seo?.ogDescription?.trim() || post?.seo?.metaDescription?.trim() || post?.excerpt}
	twitterImage={finalTwitterImage}
>
	<main class="post-page">
		<div class="container">
			{post ? (
				<article class="post">
					<a class="post__back" href="/blog/">Back to blog</a>
					<header class="post__header">
						<p class="post__meta">{formatDate(post.publishedAt)}</p>
						<h1>{post.title}</h1>
						<p class="post__excerpt">{post.excerpt}</p>
						{post.tags && post.tags.length > 0 && (
							<div class="post__tags">
								{post.tags.map((tag) => <span>{tag}</span>)}
							</div>
						)}
					</header>

					{heroImageUrl && (
						<img
							class="post__hero"
							src={heroImageUrl}
							alt={post.featuredImage?.alt ?? post.title}
							loading="eager"
						/>
					)}

					<div class="post__body prose">
						<PortableText value={post.body} />
					</div>
				</article>
			) : (
				<section class="post-missing">
					<h1>Post not found.</h1>
					<p>The requested article does not exist or is not published yet.</p>
					<a class="post__back" href="/blog/">Return to the blog</a>
				</section>
			)}
		</div>
	</main>
</Layout>

<style>
	.post-page {
		padding: 56px 0 80px;
		background:
			radial-gradient(circle at 15% 0%, rgba(37, 99, 235, 0.08), transparent 24%),
			radial-gradient(circle at 100% 10%, rgba(163, 230, 53, 0.08), transparent 20%),
			linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
	}

	.post {
		max-width: 900px;
		margin: 0 auto;
	}

	.post__back {
		display: inline-flex;
		margin-bottom: 28px;
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--color-blue);
	}

	.post__header {
		display: grid;
		gap: 16px;
	}

	.post__meta {
		font-family: 'Sora', 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-gray);
	}

	.post__header h1 {
		font-size: clamp(2.5rem, 5vw, 4.6rem);
		line-height: 1.02;
	}

	.post__excerpt {
		max-width: 60ch;
		font-size: 1.12rem;
	}

	.post__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.post__tags span {
		padding: 6px 10px;
		border-radius: 999px;
		background: rgba(37, 99, 235, 0.08);
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-black);
	}

	.post__hero {
		width: 100%;
		margin-top: 28px;
		border-radius: 28px;
		object-fit: cover;
		box-shadow: 0 24px 60px rgba(11, 11, 11, 0.12);
	}

	.post__body {
		margin-top: 36px;
		padding: 32px;
		border: 1px solid var(--color-border);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 18px 42px rgba(11, 11, 11, 0.06);
	}

	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4) {
		margin-top: 1.8em;
		margin-bottom: 0.5em;
	}

	.prose :global(p),
	.prose :global(ul),
	.prose :global(ol) {
		margin: 1em 0;
	}

	.prose :global(ul),
	.prose :global(ol) {
		padding-left: 1.4rem;
	}

	.prose :global(a) {
		color: var(--color-blue);
		text-decoration: underline;
	}

	.prose :global(blockquote) {
		margin: 1.5em 0;
		padding-left: 1rem;
		border-left: 3px solid rgba(37, 99, 235, 0.24);
		color: var(--color-black);
	}

	.prose :global(img) {
		width: 100%;
		height: auto;
		margin: 1.5em 0;
		border-radius: 18px;
	}

	.post-missing {
		max-width: 760px;
		margin: 0 auto;
		padding: 40px 32px;
		border: 1px solid var(--color-border);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.88);
		text-align: center;
	}

	@media (max-width: 700px) {
		.post-page {
			padding-top: 40px;
		}

		.post__body {
			padding: 24px 18px;
		}
	}
</style>
