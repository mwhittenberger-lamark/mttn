---
import Layout from '../../layouts/Layout.astro'
import SiteHeader from '../../components/SiteHeader.astro'
import SiteFooter from '../../components/SiteFooter.astro'
import {servicePageBySlug, servicePages, type ServicePageData} from '../../data/service-pages'

export async function getStaticPaths() {
	return servicePages.map((service) => ({
		params: {slug: service.slug},
		props: {service},
	}))
}

interface Props {
	service: ServicePageData
}

const {service} = Astro.props

const relatedServices = service.relatedServices.map((slug) => servicePageBySlug[slug]).filter(Boolean)
const structuredData = JSON.stringify({
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'BreadcrumbList',
			'@id': `https://whoisthetechninja.com/services/${service.slug}/#breadcrumb`,
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://whoisthetechninja.com/' },
				{ '@type': 'ListItem', position: 2, name: 'Services', item: 'https://whoisthetechninja.com/services/' },
				{
					'@type': 'ListItem',
					position: 3,
					name: service.shortTitle,
					item: `https://whoisthetechninja.com/services/${service.slug}/`,
				},
			],
		},
		{
			'@type': 'Service',
			'@id': `https://whoisthetechninja.com/services/${service.slug}/#service`,
			name: service.shortTitle,
			serviceType: service.shortTitle,
			description: service.metaDescription,
			areaServed: {'@type': 'AdministrativeArea', name: 'The Triangle, North Carolina'},
			provider: {
				'@type': 'LocalBusiness',
				name: 'Mike the Tech Ninja',
				url: 'https://whoisthetechninja.com/',
			},
			offers: {
				'@type': 'Offer',
				name: 'Free Digital Gut Check',
				price: '0',
				priceCurrency: 'USD',
				availability: 'https://schema.org/InStock',
				url: 'https://whoisthetechninja.com/free-digital-gut-check/',
			},
		},
	],
})
---

<Layout
	title={service.metaTitle}
	description={service.metaDescription}
	canonical={`https://whoisthetechninja.com/services/${service.slug}/`}
	robots="index, follow, max-image-preview:large"
	ogType="website"
	ogSiteName="Mike the Tech Ninja"
	ogTitle={service.metaTitle}
	ogDescription={service.metaDescription}
	ogUrl={`https://whoisthetechninja.com/services/${service.slug}/`}
	ogImage="https://whoisthetechninja.com/images/mike-the-tech-ninja-og.jpg"
	ogImageAlt="Mike the Tech Ninja logo and small business digital strategy branding"
	twitterCard="summary_large_image"
	twitterTitle={service.metaTitle}
	twitterDescription={service.metaDescription}
	twitterImage="https://whoisthetechninja.com/images/mike-the-tech-ninja-og.jpg"
	structuredData={structuredData}
>
	<div class="service-page">
		<SiteHeader />

		<main>
			<section class="service-hero">
				<div class="container service-hero__grid">
					<div class="service-hero__copy">
						<p class="service-eyebrow">{service.heroEyebrow}</p>
						<h1>{service.heroHeadline}</h1>
						<p class="service-lede">{service.heroSubheadline}</p>
						<div class="service-hero__actions">
							<a class="button primary" href="/free-digital-gut-check/">Book a Free Digital Gut Check</a>
							<a class="button secondary" href="#what-this-helps">{service.heroSecondaryCta}</a>
						</div>
						<div class="service-hero__meta">
							<span>{service.primaryKeyword}</span>
							<span>Raleigh / Cary / Durham / Chapel Hill / Apex</span>
							<span>Practical local service support</span>
						</div>
					</div>

					<div class="service-visual">
						<div class="service-visual__frame">
							<img class="service-visual__image" src={service.heroImageSrc} alt={service.heroImageAlt} loading="lazy" />
						</div>
					</div>
				</div>
			</section>

			<section class="service-section service-problems">
				<div class="container">
					<div class="service-section__head">
						<p class="service-section__eyebrow">Problem / pain</p>
						<h2>{service.problemHeadline}</h2>
						<p>{service.problemCopy}</p>
					</div>
					<div class="service-card-grid service-card-grid--six">
						{service.problemCards.map((item) => (
							<article class="service-card">
								<img src={`/icons/${service.icon}.svg`} alt="" aria-hidden="true" class="service-card__icon" />
								<h3>{item}</h3>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="service-section" id="what-this-helps">
				<div class="container service-two-up">
					<div class="service-section__head">
						<p class="service-section__eyebrow">What this service helps with</p>
						<h2>{service.helpsHeadline}</h2>
						<p>
							These are the improvements that usually make the work feel more useful, more measurable,
							and more practical for a small or medium business trying to grow without bloated overhead.
						</p>
					</div>
					<div class="service-list-panel">
						{service.helpsItems.map((item) => (
							<div class="service-check-item">
								<img src="/icons/check.svg" alt="" aria-hidden="true" />
								<span>{item}</span>
							</div>
						))}
					</div>
				</div>
			</section>

			<section class="service-section service-included" id="included">
				<div class="container">
					<div class="service-section__head narrow">
						<p class="service-section__eyebrow">What is included</p>
						<h2>{service.includedHeadline}</h2>
					</div>
					<div class="service-card-grid service-card-grid--three">
						{service.includedItems.map((item) => (
							<article class="service-module">
								<h3>{item}</h3>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="service-section">
				<div class="container service-two-up">
					<div class="service-practical">
						<p class="service-section__eyebrow">How Mike keeps it practical</p>
						<h2>{service.practicalHeadline}</h2>
						<p>{service.practicalCopy}</p>
						<div class="service-practical__links">
							<a class="button secondary" href="/#contact" data-lead-trigger={`Ask About ${service.shortTitle}`}>
								Ask About This Service
							</a>
							<a class="text-link" href="/free-digital-gut-check/">See How This Could Work for My Business</a>
						</div>
					</div>
					<div class="service-local-card">
						<p class="service-section__eyebrow">Local Triangle relevance</p>
						<h2>{service.localHeadline}</h2>
						<p>{service.localCopy}</p>
						<ul>
							<li>Raleigh, Cary, Durham, Chapel Hill, Apex, Morrisville, Holly Springs, Wake Forest, and Fuquay-Varina</li>
							<li>Local context without location-stuffing</li>
							<li>Remote-friendly support outside North Carolina too</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="service-section service-process" id="process">
				<div class="container">
					<div class="service-section__head narrow">
						<p class="service-section__eyebrow">Process</p>
						<h2>A practical process for moving the right thing first.</h2>
					</div>
					<div class="service-process__grid">
						{service.processSteps.map((step, index) => (
							<article class="service-process__item">
								<div class="service-process__step">{index + 1}</div>
								<h3>{step.title}</h3>
								<p>{step.description}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="service-section">
				<div class="container service-related-block">
					<div class="service-section__head narrow-left">
						<p class="service-section__eyebrow">Related services</p>
						<h2>Other services that often connect with this work.</h2>
					</div>
					<div class="service-card-grid service-card-grid--three">
						{relatedServices.map((related) => (
							<a class="service-related-card" href={`/services/${related.slug}/`}>
								<img src={`/icons/${related.icon}.svg`} alt="" aria-hidden="true" class="service-card__icon" />
								<h3>{related.shortTitle}</h3>
								<p>{related.metaDescription}</p>
							</a>
						))}
					</div>
				</div>
			</section>

			<section class="service-section service-related-posts">
				<div class="container service-related-block">
					<div class="service-section__head narrow-left">
						<p class="service-section__eyebrow">Relevant blog posts</p>
						<h2>Helpful reads if you want more context before booking.</h2>
					</div>
					<div class="service-card-grid service-card-grid--three">
						{service.relevantPosts.map((post) => (
							<a class="service-related-card" href={post.href}>
								<h3>{post.label}</h3>
								<p>{post.description}</p>
							</a>
						))}
					</div>
				</div>
			</section>

			<section class="service-section service-faq" id="faq">
				<div class="container service-faq__inner">
					<div class="service-section__head narrow">
						<p class="service-section__eyebrow">FAQ</p>
						<h2>Questions you may have before booking.</h2>
					</div>
					<div class="service-faq__list">
						{service.faq.map((item) => (
							<details class="service-faq__item">
								<summary>
									<span>{item.question}</span>
									<img src="/icons/chevron-down.svg" alt="" aria-hidden="true" />
								</summary>
								<p>{item.answer}</p>
							</details>
						))}
					</div>
				</div>
			</section>

			<section class="service-section service-final-cta">
				<div class="container service-final-cta__panel">
					<div>
						<h2>{service.finalCtaHeadline}</h2>
						<p>{service.finalCtaCopy}</p>
					</div>
					<div class="service-final-cta__actions">
						<a class="button primary" href="/free-digital-gut-check/">Book a Free Digital Gut Check</a>
						<a class="button secondary" href="/#contact" data-lead-trigger={`${service.shortTitle} CTA`}>
							See How This Could Work for My Business
						</a>
					</div>
				</div>
			</section>
		</main>

		<SiteFooter />
	</div>

	<script src="/scripts/site-nav.js" defer></script>
</Layout>

<style>
	.service-page {
		background:
			radial-gradient(circle at 12% 0%, rgba(37, 99, 235, 0.08), transparent 22%),
			radial-gradient(circle at 92% 6%, rgba(163, 230, 53, 0.08), transparent 18%),
			linear-gradient(180deg, #fff 0%, #f8fafc 100%);
	}

	.service-hero,
	.service-section {
		padding: 72px 0;
	}

	.service-hero {
		padding-top: 52px;
	}

	.service-hero__grid,
	.service-two-up,
	.service-final-cta__panel {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 480px);
		gap: 28px;
		align-items: start;
	}

	.service-hero__copy h1,
	.service-section__head h2,
	.service-practical h2,
	.service-local-card h2,
	.service-final-cta__panel h2 {
		max-width: 14ch;
	}

	.service-hero__copy h1 {
		margin-bottom: 14px;
	}

	.service-eyebrow,
	.service-section__eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin: 0 0 14px;
		font-family: 'Sora', sans-serif;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-blue);
	}

	.service-eyebrow::after,
	.service-section__eyebrow::after {
		content: '';
		width: 34px;
		height: 2px;
		border-radius: 999px;
		background: linear-gradient(90deg, var(--color-blue), var(--color-green));
	}

	.service-lede,
	.service-section__head p,
	.service-practical p,
	.service-local-card p,
	.service-final-cta__panel p,
	.service-related-card p,
	.service-process__item p {
		font-size: 1.06rem;
		line-height: 1.72;
		color: #475569;
	}

	.service-hero__actions,
	.service-practical__links,
	.service-final-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 24px;
	}

	.service-hero__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 26px;
	}

	.service-hero__meta span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 8px 12px;
		border-radius: 999px;
		border: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.9);
		font-size: 0.84rem;
		font-weight: 600;
	}

	.service-visual__frame {
		position: relative;
		overflow: hidden;
		padding: 14px;
		border-radius: 28px;
		border: 1px solid var(--color-border);
		background:
			radial-gradient(circle at 18% 14%, rgba(37, 99, 235, 0.12), transparent 24%),
			radial-gradient(circle at 85% 12%, rgba(163, 230, 53, 0.12), transparent 22%),
			rgba(255, 255, 255, 0.96);
		box-shadow: var(--shadow-soft);
	}

	.service-card__icon {
		width: 20px;
		height: 20px;
	}

	.service-visual__image {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 20px;
	}

	.service-module,
	.service-card,
	.service-related-card,
	.service-process__item,
	.service-list-panel,
	.service-local-card {
		border-radius: 20px;
		border: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.94);
		box-shadow: 0 14px 30px rgba(11, 11, 11, 0.05);
	}

	.service-problems {
		background: linear-gradient(180deg, rgba(245, 245, 243, 0.86), rgba(255, 255, 255, 0.96));
	}

	.service-section__head {
		max-width: 760px;
		margin-bottom: 28px;
	}

	.service-section__head.narrow,
	.service-faq__inner,
	.service-section__head.narrow-left {
		max-width: 980px;
	}

	.service-card-grid {
		display: grid;
		gap: 14px;
	}

	.service-card-grid--six {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.service-card-grid--three {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.service-card,
	.service-module,
	.service-related-card,
	.service-process__item {
		padding: 20px;
	}

	.service-card,
	.service-module,
	.service-related-card {
		border-top: 3px solid rgba(37, 99, 235, 0.24);
	}

	.service-card:nth-child(even),
	.service-module:nth-child(even),
	.service-related-card:nth-child(even) {
		border-top-color: rgba(163, 230, 53, 0.38);
	}

	.service-card h3,
	.service-module h3,
	.service-related-card h3,
	.service-process__item h3 {
		margin-top: 14px;
		font-size: 1rem;
	}

	.service-list-panel {
		padding: 20px;
		display: grid;
		gap: 12px;
	}

	.service-check-item {
		display: flex;
		align-items: flex-start;
		gap: 12px;
		padding: 14px 16px;
		border-radius: 16px;
		background: rgba(248, 250, 252, 0.92);
	}

	.service-check-item img {
		width: 18px;
		height: 18px;
		flex: 0 0 auto;
		margin-top: 2px;
	}

	.service-practical__links .text-link {
		align-self: center;
	}

	.service-local-card {
		padding: 24px;
	}

	.service-local-card ul {
		margin: 18px 0 0;
		padding-left: 18px;
		display: grid;
		gap: 10px;
	}

	.service-local-card li::marker {
		color: var(--color-green);
	}

	.service-process {
		background:
			radial-gradient(circle at 85% 12%, rgba(37, 99, 235, 0.08), transparent 20%),
			rgba(255, 255, 255, 0.98);
	}

	.service-related-posts {
		background:
			radial-gradient(circle at 12% 18%, rgba(163, 230, 53, 0.08), transparent 18%),
			transparent;
	}

	.service-process__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 14px;
	}

	.service-process__item {
		position: relative;
	}

	.service-process__step {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--color-blue), var(--color-sky));
		color: var(--color-white);
		font-family: 'Sora', sans-serif;
		font-size: 0.86rem;
		font-weight: 700;
	}

	.service-faq {
		background:
			radial-gradient(circle at 12% 18%, rgba(163, 230, 53, 0.08), transparent 18%),
			transparent;
	}

	.service-faq__list {
		display: grid;
		gap: 12px;
	}

	.service-faq__item {
		border: 1px solid var(--color-border);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.96);
		overflow: hidden;
	}

	.service-faq__item summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: 18px 20px;
		cursor: pointer;
		list-style: none;
		font-family: 'Sora', sans-serif;
		font-size: 0.96rem;
		font-weight: 600;
	}

	.service-faq__item summary::-webkit-details-marker {
		display: none;
	}

	.service-faq__item summary img {
		width: 18px;
		height: 18px;
		transition: transform 180ms ease;
	}

	.service-faq__item[open] summary img {
		transform: rotate(180deg);
	}

	.service-faq__item p {
		padding: 0 20px 18px;
		font-size: 1rem;
		line-height: 1.7;
		color: #475569;
	}

	.service-final-cta__panel {
		padding: 28px;
		border-radius: 28px;
		border: 1px solid var(--color-border);
		background:
			linear-gradient(135deg, rgba(37, 99, 235, 0.08), rgba(163, 230, 53, 0.08)),
			rgba(255, 255, 255, 0.96);
		box-shadow: var(--shadow-soft);
	}

	@media (max-width: 1024px) {
		.service-card-grid--six,
		.service-card-grid--three,
		.service-process__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 900px) {
		.service-hero__grid,
		.service-two-up,
		.service-final-cta__panel {
			grid-template-columns: 1fr;
		}

	}

	@media (max-width: 780px) {
		.service-hero,
		.service-section {
			padding: 56px 0;
		}

		.service-card-grid--six,
		.service-card-grid--three,
		.service-process__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
