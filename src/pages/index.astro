							Book a Free Digital Gut Check
						</a>
					</div>

					<a class="button primary small" href="#contact" data-lead-trigger="Nav CTA">Book a Free Digital Gut Check</a>
				</div>
			</nav>

		<main>
			<section class="hero" id="top">
				<div class="hero-bg"></div>
				<div class="floating-orb orb-left"></div>
				<div class="floating-orb orb-right"></div>
				<div class="container hero-grid">
					<div class="hero-copy">
					<div class="eyebrow-chip">
						<img class="inline-icon icon-blue" src="/icons/map-pin.svg" alt="" aria-hidden="true" />
						<span>Raleigh / Cary / Durham / Chapel Hill / The Triangle</span>
					</div>
						<h1>
							Small business budget.
							<br />
							<span>Big business digital moves.</span>
						</h1>
						<p class="lede">
							Mike the Tech Ninja helps Triangle small businesses build better websites, use practical AI,
							run smarter marketing, and turn limited budgets into real digital momentum.
						</p>
						<div class="hero-actions">
							<a class="button primary" href="#contact" data-lead-trigger="Hero CTA">Book a Free Digital Gut Check</a>
							<a class="button secondary" href="#services">See What I Can Help With</a>
						</div>
					</div>

					<div class="hero-visual">
						<div class="hero-card hero-card-services">
							<div class="mini-icon blue">
								<img class="inline-icon" src="/icons/zap.svg" alt="" aria-hidden="true" />
							</div>
							<div>
								<p class="mini-label">Services</p>
								<p>AI & Automation</p>
								<p>Web Development</p>
								<p>Digital Marketing</p>
							</div>
						</div>

						<div class="hero-card hero-card-users">
							<div class="mini-row">
								<div class="mini-icon blue">
									<img class="inline-icon" src="/icons/users.svg" alt="" aria-hidden="true" />
								</div>
								<span class="mini-label">Active Users</span>
							</div>
							<strong>50k+</strong>
							<ul>
								<li>Fast growth</li>
								<li>High engagement</li>
								<li>Trusted by local businesses</li>
							</ul>
						</div>

						<div class="hero-logo-wrap">
							<img src={logoSrc} alt="Mike the Tech Ninja logo" />
						</div>

						<div class="hero-card hero-card-growth">
							<div class="mini-row">
								<div class="mini-icon green">
									<img class="inline-icon" src="/icons/bar-chart-3.svg" alt="" aria-hidden="true" />
								</div>
								<span class="mini-label">Growth</span>
							</div>
							<strong>+127%</strong>
							<p>Year over year</p>
						</div>

						<div class="hero-card hero-card-local">
							<div class="mini-row">
								<div class="mini-icon blue">
									<img class="inline-icon" src="/icons/map-pin.svg" alt="" aria-hidden="true" />
								</div>
								<span class="mini-label">Local Focus</span>
							</div>
							<p>Serving the Triangle area</p>
							<div class="meter">
								<div></div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="section intro">
				<div class="section-glow"></div>
				<div class="container intro-inner">
					<h2>
						You do not need a giant agency
						<br />
						<span>to make serious digital progress.</span>
					</h2>

					<div class="intro-copy">
						<p>
							Most small businesses do not need a bloated marketing retainer, a 60-page strategy deck, or a
							website project that takes six months. They need someone experienced enough to see the whole
							picture and practical enough to fix the next right thing.
						</p>
					</div>

					<div class="statement-pill">That is where Mike the Tech Ninja comes in.</div>

					<div class="intro-panel">
						<p>
							I help small businesses across the Triangle improve the digital pieces that actually affect
							growth: websites, landing pages, paid traffic, SEO, email marketing, conversion paths,
							analytics, and AI-powered workflows.
						</p>
					</div>
						<a class="button primary intro-cta" href="#contact" data-lead-trigger="Intro CTA">Let's Grow Your Business</a>
				</div>
			</section>

			<section class="section problems">
				<div class="container">
						<div class="section-head narrow">
							<h2>Small businesses are being asked to compete like big businesses.</h2>
							<p>
								Customers expect a fast website, clear messaging, easy booking or buying, helpful follow-up,
								search visibility, and marketing that feels relevant.
							</p>
						</div>

						<div class="problem-wrap">
							<p class="problem-label">Common bottlenecks I see most often</p>
							<div class="problem-grid">
								{problemCards.map(([icon, title, description]) => (
									<article class="problem-card">
										<div class="problem-head">
											<div class="problem-icon">
												<img class="inline-icon icon-red" src={`/icons/${icon}.svg`} alt="" aria-hidden="true" />
											</div>
											<h3>{title}</h3>
										</div>
										<p>{description}</p>
									</article>
								))}
							</div>
						</div>
					</div>
				</section>

				<section class="section services-band" id="services">
					<div class="container">
						<div class="section-split">
							<div class="section-head">
							<h2>Practical digital help for small businesses that need results, not jargon.</h2>
						</div>
						<a class="text-link" href="#packages">See all services</a>
					</div>

					<div class="service-grid">
						{services.map((service) => (
							<article class="service-card">
								<div class="service-icon">
									<img class="inline-icon icon-dark" src={`/icons/${service.icon}.svg`} alt="" aria-hidden="true" />
								</div>
								<h3>{service.title}</h3>
								<p>{service.description}</p>
								<div class="tag-list">
									{service.tags.map((tag) => <span>{tag}</span>)}
								</div>
							</article>
						))}
						</div>
					</div>
				</section>

				<section class="section process-band" id="how-it-works">
					<div class="container narrow-center">
						<h2>A simple process that keeps the work focused</h2>
						<div class="process-grid">
							{processSteps.map(([step, title, description]) => (
								<article class="process-card">
									<div class="process-step">{step}</div>
									<h3>{title}</h3>
									<p>{description}</p>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="section leverage">
					<div class="container narrow-center">
						<h2>How I make a small budget feel bigger</h2>
						<p class="center-intro">A bigger budget is helpful, but a smarter plan usually matters more.</p>

					<div class="leverage-grid">
						{leveragePoints.map(([icon, title, description], index) => (
							<article class="leverage-item">
								<div class="leverage-icon">
									<img class="inline-icon icon-blue" src={`/icons/${icon}.svg`} alt="" aria-hidden="true" />
								</div>
								<div>
									<h3>{title}</h3>
									<p>{description}</p>
								</div>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="section triangle-band">
				<div class="container triangle-grid">
					<div class="triangle-copy">
						<div class="eyebrow-chip light">
							<img class="inline-icon icon-blue" src="/icons/map-pin.svg" alt="" aria-hidden="true" />
							<span>Local to the Triangle</span>
						</div>
						<h2>Built for Triangle businesses</h2>
						<p>
							If you run a business in Raleigh, Cary, Apex, Durham, Chapel Hill, Morrisville, Holly Springs,
							Wake Forest, Fuquay-Varina, or anywhere nearby, I can help remotely or in person.
						</p>
						<p class="emphasis">
							Sometimes the best marketing starts by seeing the business through a customer's eyes.
						</p>
							<a class="button primary" href="#contact" data-lead-trigger="Triangle CTA">Let's Grow Your Business</a>
					</div>

						<div class="triangle-map">
							<div class="map-surface">
								<iframe
									src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d415698.0173815952!2d-79.13320893750001!3d35.87471795!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89ace6c6c9b5b7f3%3A0x13ff1d85d601c1e2!2sResearch%20Triangle%20Park%2C%20NC!5e0!3m2!1sen!2sus!4v1234567890123!5m2!1sen!2sus"
									title="Research Triangle Park Map"
									loading="lazy"
									referrerpolicy="no-referrer-when-downgrade"
								></iframe>
								<div class="map-overlay">
									{cities.map((city, index) => (
										<div class={`city-pill city-${index + 1}`}>
											<img class="inline-icon icon-blue" src="/icons/map-pin.svg" alt="" aria-hidden="true" />
											<span>{city}</span>
										</div>
									))}
								</div>
							</div>
						</div>
				</div>
			</section>

			<section class="section packages" id="packages">
				<div class="container">
					<div class="section-head center">
						<h2>Start with the next right move.</h2>
						<p>Choose the option that fits where you are today.</p>
					</div>

					<div class="package-grid">
						{packages.map((pkg) => (
							<article class:list={['package-card', pkg.highlighted && 'highlighted']}>
								<h3>{pkg.title}</h3>
								<p>{pkg.description}</p>
								<div class="package-price">{pkg.price}</div>
									<a class:list={['button', pkg.highlighted ? 'primary' : 'secondary', 'small']} href="#contact" data-lead-trigger={pkg.title}>
										{pkg.cta}
									</a>
							</article>
						))}
					</div>
				</div>
			</section>

				<section class="section about">
				<div class="container about-inner">
					<div class="about-logo">
						<img src={logoSrc} alt="Mike the Tech Ninja" />
					</div>
					<div class="about-copy">
						<h2>Meet Mike, your local Tech Ninja</h2>
						<p>
							I have spent my career building websites, digital tools, marketing systems, and AI-powered
							solutions for businesses that need the web to do more than simply exist.
						</p>
						<p>
							My background spans web development, custom AI, apps, lifecycle and email marketing, paid media,
							SEO, CRO, and digital strategy.
						</p>
						<p class="emphasis">
							If you are in the Triangle, I can work with you remotely or meet in person to understand your
							business, your customers, and the opportunities hiding in plain sight.
						</p>
							<a class="button primary about-cta" href="#contact" data-lead-trigger="About CTA">Let's Talk About What's Possible</a>
					</div>
				</div>
			</section>

			<section class="section faq-band" id="faq">
				<div class="container faq-inner">
					<h2>Frequently Asked Questions</h2>
						<div class="faq-list">
							{faqItems.map(([question, answer]) => (
								<details class="faq-item">
									<summary>
										<span>{question}</span>
										<img class="faq-chevron" src="/icons/chevron-down.svg" alt="" aria-hidden="true" />
									</summary>
									<p>{answer}</p>
								</details>
							))}
						</div>
				</div>
			</section>

			<section class="section final-cta" id="contact">
				<div class="container">
					<div class="cta-panel">
						<h2>Ready to make your digital presence work harder?</h2>
						<p>Bring the business problem. I will help you figure out the smartest digital move.</p>
							<a class="button primary" href="#contact" data-lead-trigger="Final CTA">Book a Free Digital Gut Check</a>
						</div>
					</div>
				</section>
			</main>

			<div class="lead-modal" id="lead-modal" hidden>
				<div class="lead-modal__backdrop" data-lead-close></div>
				<div
					class="lead-modal__dialog"
					role="dialog"
					aria-modal="true"
					aria-labelledby="lead-modal-title"
				>
					<button class="lead-modal__close" type="button" aria-label="Close form" data-lead-close>
						<span></span>
						<span></span>
					</button>
					<div class="lead-modal__content">
						<p class="lead-modal__eyebrow">Let's talk</p>
						<h2 id="lead-modal-title">Let's Talk About What's Possible</h2>
						<p class="lead-modal__copy">
							Share a few details and I will reach out to talk through the smartest next move for your
							business.
						</p>
						<form class="lead-form" id="lead-form">
							<input type="hidden" name="source" id="lead-source" value="" />
							<div class="lead-form__grid">
								<label>
									<span>First name</span>
									<input type="text" name="first_name" autocomplete="given-name" required />
								</label>
								<label>
									<span>Last name</span>
									<input type="text" name="last_name" autocomplete="family-name" required />
								</label>
							</div>
							<label>
								<span>Email</span>
								<input type="email" name="email" autocomplete="email" required />
							</label>
							<label>
								<span>Phone</span>
								<input type="tel" name="phone" autocomplete="tel" required />
							</label>
							<button class="button primary lead-form__submit" type="submit">Request My Callback</button>
							<p class="lead-form__note">Required: first and last name, email, and phone.</p>
							<p class="lead-form__error" id="lead-error" hidden>
								That did not go through. Please try again in a moment.
							</p>
						</form>
						<div class="lead-success-card" id="lead-success" hidden>
							<p class="lead-success-card__eyebrow">Request received</p>
							<h3>Thanks. Your Digital Gut Check request is in.</h3>
							<p>
								I have your details and will follow up soon to talk through the smartest next move for
								your business.
							</p>
							<button class="button primary" type="button" data-lead-close>Close</button>
						</div>
					</div>
				</div>
			</div>

				<footer class="site-footer">
				<div class="container footer-inner">
					<div class="footer-brand">
						<img src={logoSrc} alt="Mike the Tech Ninja" />
						<div>
							<div class="footer-title">Mike the Tech Ninja</div>
							<div class="footer-subtitle">Serving the Triangle, NC</div>
						</div>
					</div>
					<div class="footer-socials">
						{socialLinks.map((link) => (
							<a href={link.href} aria-label={link.label}>
								{link.icon === 'twitter' && (
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path d="M23 3a10.9 10.9 0 0 1-3.14 1.53A4.48 4.48 0 0 0 12 7.53v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
									</svg>
								)}
								{link.icon === 'linkedin' && (
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
										<rect x="2" y="9" width="4" height="12"></rect>
										<circle cx="4" cy="4" r="2"></circle>
									</svg>
								)}
								{link.icon === 'github' && (
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
									</svg>
								)}
							</a>
						))}
					</div>
				</div>
				<div class="container footer-services">
					<p>
						{services.map((service) => service.title).join(' / ')}
					</p>
				</div>
				<div class="container footer-note">
					<p>&copy; 2026 Mike the Tech Ninja. All rights reserved.</p>
				</div>
			</footer>
	</div>
</Layout>

