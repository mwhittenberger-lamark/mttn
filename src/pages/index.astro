            "@type": "Answer",
            "text": "Yes. Some businesses need a one-time project. Others need ongoing help with campaigns, website improvements, email, SEO, AI tools, analytics, and strategy."
          }
        },
        {
          "@type": "Question",
          "@id": "https://whoisthetechninja.com/#faq-cheaper-than-agency",
          "name": "Are you cheaper than an agency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Usually, yes. More importantly, the work is structured around what makes sense for the business and budget instead of forcing every client into a large retainer."
          }
        },
        {
          "@type": "Question",
          "@id": "https://whoisthetechninja.com/#faq-existing-website-marketing-person",
          "name": "What if I already have a website or marketing person?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "That is fine. Mike the Tech Ninja can help with specific projects, audits, AI tools, landing pages, strategy, technical fixes, or areas where the current setup needs extra support."
          }
        }
      ]
    }
  ]
}`;
---

<Layout
	title="Mike the Tech Ninja | Small Business Websites, AI & Marketing in Raleigh NC"
	description="Mike the Tech Ninja helps Triangle small businesses with websites, custom AI, paid media, SEO, email marketing, CRO, apps, and digital strategy. Book a free Digital Gut Check."
	canonical="https://whoisthetechninja.com/"
	robots="index, follow, max-image-preview:large"
	structuredData={structuredData}
	ogType="website"
	ogSiteName="Mike the Tech Ninja"
	ogTitle="Small Business Budget. Big Business Digital Moves."
	ogDescription="Websites, custom AI, apps, paid media, SEO, email marketing, CRO, and digital strategy for Triangle small businesses."
	ogUrl="https://whoisthetechninja.com/"
	ogImage="https://whoisthetechninja.com/images/mike-the-tech-ninja-og.jpg"
	ogImageAlt="Mike the Tech Ninja logo and small business digital strategy branding"
	twitterCard="summary_large_image"
	twitterTitle="Mike the Tech Ninja | Websites, AI & Marketing for Small Businesses"
	twitterDescription="Practical websites, AI, apps, marketing, SEO, email, CRO, and strategy for Triangle small businesses."
	twitterImage="https://whoisthetechninja.com/images/mike-the-tech-ninja-og.jpg"
>
	<div class="progress" aria-hidden="true"><div class="progress-bar"></div></div>

		<div class="page">
			<nav class="site-nav" id="site-nav">
				<div class="container nav-inner">
					<a class="brand" href="#top">
						<img src={logoSrc} alt="Mike the Tech Ninja logo" />
						<span>Mike the Tech Ninja</span>
					</a>

					<a class="button primary small nav-mobile-consult" href="#contact" data-lead-trigger="Nav CTA">
						Free Consult
					</a>
					<button
						class="nav-toggle"
						type="button"
						aria-expanded="false"
						aria-controls="primary-nav"
						aria-label="Open navigation menu"
					>
						<span></span>
						<span></span>
						<span></span>
					</button>

					<div class="nav-links" id="primary-nav">
						{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
						<a class="button primary small nav-links__cta" href="#contact" data-lead-trigger="Nav CTA">
							Free Consult
						</a>
					</div>
					<a class="button primary small" href="#contact" data-lead-trigger="Nav CTA">Book a Free Digital Gut Check</a>
				</div>
			</nav>

		<main>
			<section class="hero" id="top">
				<div class="hero-bg"></div>
				<div class="hero-pattern hero-pattern-grid" aria-hidden="true"></div>
				<div class="hero-pattern hero-pattern-contour" aria-hidden="true"></div>
				<div class="floating-orb orb-left"></div>
				<div class="floating-orb orb-right"></div>
				<div class="container hero-grid">
					<div class="hero-copy">
					<div class="eyebrow-chip">
						<img class="inline-icon icon-blue" src="/icons/map-pin.svg" alt="" aria-hidden="true" />
						<span>Raleigh / Cary / Durham / Chapel Hill / The Triangle</span>
					</div>
						<h1>
							Small business budget.
							<br />
							<span>Big business digital moves.</span>
						</h1>
						<p class="lede">
							Mike the Tech Ninja helps Triangle small businesses build better websites, use practical AI,
							run smarter marketing, and turn limited budgets into real digital momentum.
						</p>
						<div class="hero-actions">
							<a class="button primary" href="#contact" data-lead-trigger="Hero CTA">Book a Free Digital Gut Check</a>
							<a class="button secondary" href="#services">See What I Can Help With</a>
						</div>
					</div>

					<div class="hero-visual">
						<div class="hero-card hero-card-services">
							<div class="mini-icon blue">
								<img class="inline-icon" src="/icons/zap.svg" alt="" aria-hidden="true" />
							</div>
							<div>
								<p class="mini-label">Services</p>
								<p>AI & Automation</p>
								<p>Web Development</p>
								<p>Digital Marketing</p>
							</div>
						</div>

						<div class="hero-card hero-card-users">
							<div class="mini-row">
								<div class="mini-icon blue">
									<img class="inline-icon" src="/icons/users.svg" alt="" aria-hidden="true" />
								</div>
								<span class="mini-label">Active Users</span>
							</div>
							<strong>50k+</strong>
							<ul>
								<li>Fast growth</li>
								<li>High engagement</li>
								<li>Trusted by local businesses</li>
							</ul>
						</div>

						<div class="hero-logo-wrap">
							<img src={logoSrc} alt="Mike the Tech Ninja logo" />
						</div>

						<div class="hero-card hero-card-growth">
							<div class="mini-row">
								<div class="mini-icon green">
									<img class="inline-icon" src="/icons/bar-chart-3.svg" alt="" aria-hidden="true" />
								</div>
								<span class="mini-label">Growth</span>
							</div>
							<strong>+127%</strong>
							<p>Year over year</p>
						</div>

						<div class="hero-card hero-card-local">
							<div class="mini-row">
								<div class="mini-icon blue">
									<img class="inline-icon" src="/icons/map-pin.svg" alt="" aria-hidden="true" />
								</div>
								<span class="mini-label">Local Focus</span>
							</div>
							<p>Serving the Triangle area</p>
							<div class="meter">
								<div></div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="section intro">
				<div class="section-glow"></div>
				<div class="container intro-inner">
					<h2>
						You do not need a giant agency
						<br />
						<span>to make serious digital progress.</span>
					</h2>

					<div class="intro-copy">
						<p>
							Most small businesses do not need a bloated marketing retainer, a 60-page strategy deck, or a
							website project that takes six months. They need someone experienced enough to see the whole
							picture and practical enough to fix the next right thing.
						</p>
					</div>

					<div class="statement-pill">That is where Mike the Tech Ninja comes in.</div>

					<div class="intro-panel">
						<p>
							I help small businesses across the Triangle improve the digital pieces that actually affect
							growth: websites, landing pages, paid traffic, SEO, email marketing, conversion paths,
							analytics, and AI-powered workflows.
						</p>
					</div>
					<p class="intro-business-types">
						Local service businesses <span aria-hidden="true">&bull;</span> Health and wellness practices
						<span aria-hidden="true">&bull;</span> Professional services <span aria-hidden="true">&bull;</span>
						Retail and ecommerce brands <span aria-hidden="true">&bull;</span> Restaurants and hospitality
						businesses <span aria-hidden="true">&bull;</span> Creators and side hustles
					</p>
						<a class="button primary intro-cta" href="#contact" data-lead-trigger="Intro CTA">Let's Grow Your Business</a>
				</div>
			</section>

			<section class="section problems">
				<div class="container">
						<div class="problem-intro">
							<div class="section-head narrow">
								<h2>Small businesses are being asked to compete like big businesses.</h2>
								<p>
									Customers expect a fast website, clear messaging, easy booking or buying, helpful follow-up,
									search visibility, and marketing that feels relevant.
								</p>
							</div>
							<div class="problem-visual">
								<img
									src="/small-business-hero.webp"
									alt="Triangle small business owner using website, SEO, email marketing, booking, and digital growth tools"
									loading="lazy"
								/>
							</div>
						</div>

						<div class="problem-wrap">
							<p class="problem-label">Common bottlenecks I see most often</p>
							<div class="problem-grid">
								{problemCards.map(([icon, title, description]) => (
									<article class="problem-card">
										<div class="problem-head">
											<div class="problem-icon">
												<img class="inline-icon icon-red" src={`/icons/${icon}.svg`} alt="" aria-hidden="true" />
											</div>
											<h3>{title}</h3>
										</div>
										<p>{description}</p>
									</article>
								))}
							</div>
						</div>
					</div>
				</section>

				<section class="section services-band" id="services">
					<div class="container">
						<div class="section-split">
							<div class="section-head">
							<h2>Practical digital help for small businesses that need results, not jargon.</h2>
						</div>
						<a class="text-link" href="#packages">See all services</a>
					</div>

					<div class="service-grid">
						{services.map((service) => (
							<a class="service-card" href={service.href}>
								<div class="service-icon">
									<img class="inline-icon icon-dark" src={`/icons/${service.icon}.svg`} alt="" aria-hidden="true" />
								</div>
								<h3>{service.title}</h3>
								<p>{service.description}</p>
								<div class="tag-list">
									{service.tags.map((tag) => <span>{tag}</span>)}
								</div>
								<div class="service-card__cta">
									<span>Learn more</span>
									<img class="inline-icon icon-blue" src="/icons/arrow-right.svg" alt="" aria-hidden="true" />
								</div>
							</a>
						))}
						</div>
					</div>
				</section>

				<section class="section process-band" id="how-it-works">
					<div class="container narrow-center">
						<h2>A simple process that keeps the work focused</h2>
						<div class="process-grid">
							{processSteps.map(([step, title, description]) => (
								<article class="process-card">
									<div class="process-step">{step}</div>
									<h3>{title}</h3>
									<p>{description}</p>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="section leverage">
					<div class="container narrow-center">
						<h2>How I make a small budget feel bigger</h2>
						<p class="center-intro">A bigger budget is helpful, but a smarter plan usually matters more.</p>

					<div class="leverage-grid">
						{leveragePoints.map(([icon, title, description], index) => (
							<article class="leverage-item">
								<div class="leverage-icon">
									<img class="inline-icon icon-blue" src={`/icons/${icon}.svg`} alt="" aria-hidden="true" />
								</div>
								<div>
									<h3>{title}</h3>
									<p>{description}</p>
								</div>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="section triangle-band">
				<div class="container triangle-grid">
					<div class="triangle-copy">
						<div class="eyebrow-chip light">
							<img class="inline-icon icon-blue" src="/icons/map-pin.svg" alt="" aria-hidden="true" />
							<span>Local to the Triangle</span>
						</div>
						<h2>Built for Triangle businesses</h2>
						<p>
							If you run a business in Raleigh, Cary, Apex, Durham, Chapel Hill, Morrisville, Holly Springs,
							Wake Forest, Fuquay-Varina, or anywhere nearby, I can help remotely or in person.
						</p>
						<p class="emphasis">
							Sometimes the best marketing starts by seeing the business through a customer's eyes.
						</p>
							<a class="button primary" href="#contact" data-lead-trigger="Triangle CTA">Let's Grow Your Business</a>
					</div>

						<div class="triangle-map">
							<div class="map-surface">
								<iframe
									src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d415698.0173815952!2d-79.13320893750001!3d35.87471795!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89ace6c6c9b5b7f3%3A0x13ff1d85d601c1e2!2sResearch%20Triangle%20Park%2C%20NC!5e0!3m2!1sen!2sus!4v1234567890123!5m2!1sen!2sus"
									title="Research Triangle Park Map"
									loading="lazy"
									referrerpolicy="no-referrer-when-downgrade"
								></iframe>
								<div class="map-overlay">
									{cities.map((city, index) => (
										<div class={`city-pill city-${index + 1}`}>
											<img class="inline-icon icon-blue" src="/icons/map-pin.svg" alt="" aria-hidden="true" />
											<span>{city}</span>
										</div>
									))}
								</div>
							</div>
						</div>
				</div>
			</section>

			<section class="section packages" id="packages">
				<div class="container">
					<div class="section-head center">
						<h2>Start with the next right move.</h2>
						<p>Choose the option that fits where you are today.</p>
					</div>

					<div class="package-grid">
						{packages.map((pkg) => (
							<article class:list={['package-card', pkg.highlighted && 'highlighted']}>
								<p class="package-eyebrow">{pkg.eyebrow}</p>
								<h3>{pkg.title}</h3>
								<p class="package-best-for">{pkg.bestFor}</p>
								<p>{pkg.description}</p>
								<div class="package-price">{pkg.price}</div>
									<button
										class:list={['button', pkg.highlighted ? 'primary' : 'secondary', 'small']}
										type="button"
										data-offer-trigger={pkg.id}
									>
										{pkg.cta}
									</button>
							</article>
						))}
					</div>
				</div>
			</section>

				<section class="section about">
				<div class="container about-inner">
					<div class="about-logo">
						<img src={logoSrc} alt="Mike the Tech Ninja logo" />
					</div>
					<div class="about-copy">
						<h2>Meet Mike, your local Tech Ninja</h2>
						<p>
							I have been doing this for over 20 years, building websites, digital tools, marketing
							systems, and AI-powered solutions for businesses that need the web to do more than simply
							exist.
						</p>
						<p>
							My background spans web development, custom AI, apps, lifecycle and email marketing, paid media,
							SEO, CRO, and digital strategy.
						</p>
						<p class="emphasis">
							If you are in the Triangle, I can work with you remotely or meet in person to understand your
							business, your customers, and the opportunities hiding in plain sight.
						</p>
						<a class="button primary about-cta" href="#contact" data-lead-trigger="About CTA">Let's Talk About What's Possible</a>
					</div>
					<div class="about-work">
						<div class="section-head center">
							<h3>Selected Work</h3>
							<p>A few examples of brands and businesses I have helped build or support.</p>
						</div>
						<div class="portfolio-grid">
							{portfolioItems.map((item) => (
								<a
									class="portfolio-card"
									href={item.url}
									target="_blank"
									rel="noreferrer"
									aria-label={`Open ${item.name} in a new tab`}
								>
									<div class="portfolio-logo-wrap">
										<img src={item.logo} alt={item.logoAlt} class="portfolio-logo" loading="lazy" />
									</div>
									<p class="portfolio-platform">{item.platform}</p>
									<h3>{item.name}</h3>
									<p>{item.description}</p>
									<span class="portfolio-link">Visit Site</span>
								</a>
							))}
						</div>
					</div>
				</div>
			</section>

			<section class="section faq-band" id="faq">
				<div class="container faq-inner">
					<h2>Frequently Asked Questions</h2>
						<div class="faq-list">
							{faqItems.map(([question, answer]) => (
								<details class="faq-item">
									<summary>
										<span>{question}</span>
										<img class="faq-chevron" src="/icons/chevron-down.svg" alt="" aria-hidden="true" />
									</summary>
									<p>{answer}</p>
								</details>
							))}
						</div>
				</div>
			</section>

			<section class="section final-cta" id="contact">
				<div class="container">
					<div class="cta-panel">
						<h2>Ready to make your digital presence work harder?</h2>
						<p>Bring the business problem. I will help you figure out the smartest digital move.</p>
							<a class="button primary" href="#contact" data-lead-trigger="Final CTA">Book a Free Digital Gut Check</a>
						</div>
					</div>
				</section>
			</main>

			<div class="offer-modal" id="offer-modal" hidden>
				<div class="offer-modal__backdrop" data-offer-close></div>
				<div
					class="offer-modal__dialog"
					role="dialog"
					aria-modal="true"
					aria-label="Offer details"
				>
					<button class="offer-modal__close" type="button" aria-label="Close offer details" data-offer-close>
						<span></span>
						<span></span>
					</button>
					<div class="offer-modal__panels">
						{packages.map((pkg) => (
							<section class="offer-panel" data-offer-panel={pkg.id} hidden>
								<p class="offer-panel__eyebrow">{pkg.eyebrow}</p>
								<h2>{pkg.title}</h2>
								<p class="offer-panel__price">{pkg.price}</p>
								<p class="offer-panel__description">{pkg.description}</p>
								<p class="offer-panel__best-for">{pkg.bestFor}</p>
								<div class="offer-panel__body">
									<div>
										<h3>What is included</h3>
										<ul class="offer-panel__list">
											{pkg.includes.map((item) => <li>{item}</li>)}
										</ul>
									</div>
									<div class="offer-panel__outcome">
										<h3>Outcome</h3>
										<p>{pkg.outcome}</p>
									</div>
								</div>
								<div class="offer-panel__actions">
									<button class="button primary" type="button" data-offer-lead-trigger={pkg.title}>
										{pkg.id === 'triangle-digital-tune-up' ? 'Request a Digital Tune-Up' : 'Let’s Talk About This Offer'}
									</button>
									<button class="button secondary small" type="button" data-offer-close>
										Keep Browsing
									</button>
								</div>
							</section>
						))}
					</div>
				</div>
			</div>

			<SiteFooter />
	</div>
</Layout>

<script src="/scripts/homepage.js" defer></script>
