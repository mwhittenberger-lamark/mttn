---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';

const logoSrc = '/mike%20the%20tech%20ninja%20logo%202026.png';

const marketQuestions = [
	'Can shoppers easily buy from you online?',
	'Are they joining your email list?',
	'Can they find you on Google?',
	'Do they know when your next drop or market is coming?',
	'Are past customers hearing from you again?',
];

const reviewCards = [
	[
		'Shopify and online selling',
		'If you sell through Shopify, Etsy, Square, WooCommerce, Instagram, or Facebook, we can review how easy it is for people to browse, trust, and buy from you online.',
		'We can look at product pages, collections, mobile experience, checkout flow, photos, descriptions, bundles, seasonal drops, and ways to make your online shop feel more like your in-person booth.',
	],
	[
		'Email and customer follow-up',
		'A person who buys once should not disappear forever.',
		'We can talk about simple ways to stay connected, including welcome emails, post-purchase thank-yous, product care tips, upcoming market reminders, new product announcements, seasonal gift guides, abandoned cart emails, and repeat customer offers.',
	],
	[
		'SEO and local visibility',
		'People search for local artists, handmade gifts, custom products, and market vendors.',
		'We can review whether your website, shop, social profiles, and Google presence make it easy for people to find you.',
	],
	[
		'Paid media and event promotion',
		'Ads are not always the first move. But when the timing is right, they can help promote holiday offers, upcoming markets, product launches, best sellers, or local events.',
		'We can talk through whether paid ads make sense now, later, or not yet.',
	],
];

const takeawayCards = [
	[
		'A clearer sense of what is holding you back',
		'We will look for the friction points that may be making it harder for people to discover, trust, buy, or return.',
	],
	[
		'2-3 practical next steps',
		'No giant wish list. Just a few realistic moves that could help your business make progress.',
	],
	[
		'A better idea of what to fix first',
		'Some things are urgent. Some things can wait. Some things are not worth spending money on yet.',
	],
];

const sellerItems = [
	'Handmade goods',
	'Art prints or original artwork',
	'Jewelry',
	'Candles',
	'Soaps, skincare, or wellness products',
	'Clothing or accessories',
	'Woodwork, pottery, leather goods, or home decor',
	'Custom gifts',
	'Food products or packaged treats',
	'Creative services or digital products',
];

const audienceItems = [
	'Raleigh',
	'Cary',
	'Durham',
	'Chapel Hill',
	'Apex',
	'Triangle makers',
];

const structuredData = JSON.stringify({
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebPage',
			'@id': 'https://whoisthetechninja.com/nc-makers/#webpage',
			url: 'https://whoisthetechninja.com/nc-makers/',
			name: 'Free Digital Gut Check for NC Makers | Mike the Tech Ninja',
			description:
				'Free Digital Gut Check for Triangle makers, artists, crafters, vendors, and side hustlers who want more repeat customers after markets, fairs, and pop-ups.',
			inLanguage: 'en-US',
		},
	],
});
---

<Layout
	title="Free Digital Gut Check for NC Makers | Mike the Tech Ninja"
	description="Free Digital Gut Check for Triangle makers, artists, crafters, vendors, and side hustlers who want more repeat customers after markets, fairs, and pop-ups."
	canonical="https://whoisthetechninja.com/nc-makers/"
	robots="index, follow, max-image-preview:large"
	ogType="website"
	ogSiteName="Mike the Tech Ninja"
	ogTitle="Turn Market Shoppers Into Repeat Customers"
	ogDescription="A free Digital Gut Check for Triangle makers, artists, crafters, vendors, and side hustlers."
	ogUrl="https://whoisthetechninja.com/nc-makers/"
	ogImage="https://whoisthetechninja.com/images/mike-the-tech-ninja-og.jpg"
	ogImageAlt="Mike the Tech Ninja logo and creative business digital strategy branding"
	twitterCard="summary_large_image"
	twitterTitle="Turn Market Shoppers Into Repeat Customers"
	twitterDescription="A free Digital Gut Check for Triangle makers, artists, crafters, vendors, and side hustlers."
	twitterImage="https://whoisthetechninja.com/images/mike-the-tech-ninja-og.jpg"
	structuredData={structuredData}
>
	<div class="landing-shell">
		<header class="landing-topbar">
			<div class="container landing-topbar__inner">
				<a class="landing-brand" href="/">
					<img src={logoSrc} alt="Mike the Tech Ninja logo" />
					<span>Mike the Tech Ninja</span>
				</a>
				<a class="button primary small" href="#gut-check-form">Book My Free Digital Gut Check</a>
			</div>
		</header>

		<main>
			<section class="gut-hero">
				<div class="gut-hero__grid container">
					<div class="gut-hero__copy">
						<p class="gut-eyebrow">For Triangle makers, artists, crafters, vendors, and side hustlers</p>
						<h1>Turn Market Shoppers Into Repeat Customers</h1>
						<p class="gut-lede">
							You make great things. Your digital setup should make it easier for people to find you,
							buy from you, and come back after the market is over.
						</p>
						<p class="gut-hero__support">
							If you sell at craft fairs, pop-ups, vendor events, art shows, festivals, or local
							markets around Raleigh, Cary, Durham, Chapel Hill, Apex, or the Triangle, this free
							30-minute review is built for you.
						</p>
						<div class="gut-hero__actions">
							<a class="button primary" href="#gut-check-form">Book My Free Digital Gut Check</a>
							<p class="gut-trust-line">Practical advice for creative businesses that sell in person and online.</p>
						</div>
						<div class="gut-audience">
							{audienceItems.map((item) => <span>{item}</span>)}
						</div>
					</div>

					<div class="gut-form-card" id="gut-check-form">
						<p class="gut-form-card__eyebrow">Free 30-minute review</p>
						<h2>Book your Digital Gut Check</h2>
						<p>
							Tell me a little about what you make, where you sell, and what you want to improve. I
							will follow up personally.
						</p>

						<form class="gut-form" id="paid-landing-form">
							<input type="hidden" name="source" value="NC Makers Landing Page" />
							<div class="gut-form__pane is-active" data-form-step="1">
								<div class="gut-form__grid gut-form__grid--two">
									<label>
										<span>First name</span>
										<input type="text" name="first_name" autocomplete="given-name" required />
									</label>
									<label>
										<span>Last name</span>
										<input type="text" name="last_name" autocomplete="family-name" required />
									</label>
								</div>
								<div class="gut-form__grid gut-form__grid--two">
									<label>
										<span>Business name</span>
										<input type="text" name="business_name" autocomplete="organization" required />
									</label>
									<label>
										<span>Website or shop URL</span>
										<input type="url" name="website_url" placeholder="https://example.com" />
									</label>
								</div>
								<div class="gut-form__grid gut-form__grid--two">
									<label>
										<span>Email</span>
										<input type="email" name="email" autocomplete="email" required />
									</label>
									<label>
										<span>Phone</span>
										<input type="tel" name="phone" autocomplete="tel" required />
									</label>
								</div>
								<div class="gut-form__actions">
									<button class="button primary gut-form__next" type="button" data-step-next>
										Next Step
									</button>
								</div>
							</div>
							<div class="gut-form__pane" data-form-step="2" hidden>
								<label>
									<span>What is the biggest thing you want to improve?</span>
									<textarea name="biggest_improvement" rows="4" required></textarea>
								</label>
								<label class="gut-form__consent">
									<input type="checkbox" name="sms_opt_in" value="yes" />
									<span>
										I agree to be contacted by SMS about scheduling my call. Message and data
										rates may apply. Consent is not a condition of purchase. See the
										<a href="/privacy-policy/" target="_blank" rel="noreferrer">Privacy Policy</a>
										and
										<a href="/terms-of-service/" target="_blank" rel="noreferrer">Terms of Service</a>.
									</span>
								</label>
								<div class="gut-form__actions">
									<button class="button secondary" type="button" data-step-back>Back</button>
									<button class="button primary gut-form__submit" type="submit">Schedule My Free Gut Check</button>
								</div>
							</div>
							<p class="gut-form__note">
								No pressure. No bloated proposal. Just practical advice for your creative business.
							</p>
							<p class="gut-form__error" id="paid-landing-error" hidden>
								That did not go through. Please try again in a moment.
							</p>
						</form>

						<div class="gut-success" id="paid-landing-success" hidden>
							<p class="gut-success__eyebrow">Request received</p>
							<h3>Your Digital Gut Check request is in.</h3>
							<p>I have your details and will follow up soon with the next step.</p>
							<p>In the meantime, check out the blog for practical tips on websites, AI, SEO, and smarter digital growth.</p>
							<div class="gut-success__actions">
								<a class="button secondary" href="/blog/">Browse the Blog</a>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="gut-section gut-pain">
				<div class="container gut-pain__grid">
					<div class="gut-pain__copy">
						<p class="gut-section__eyebrow">After the event</p>
						<h2>Your booth gets attention. What happens after they walk away?</h2>
						<p class="gut-section__intro">
							Selling in person is powerful. People meet you, hear your story, and see the work up
							close.
						</p>
						<p class="gut-section__body">But after the event, many makers lose the connection.</p>
						<div class="gut-pain__card">
							<ul class="gut-question-list">
								{marketQuestions.map((item) => <li>{item}</li>)}
							</ul>
							<p class="gut-section__closing">
								You may not need a huge marketing plan. You may just need the right next few fixes.
							</p>
						</div>
					</div>
					<div class="gut-pain__image-wrap">
						<img
							class="gut-pain__image"
							src="/nc-makers-vendor.webp"
							alt="Mike the Tech Ninja speaking with a market vendor about Shopify, email, search, and repeat customer growth"
							loading="lazy"
						/>
					</div>
				</div>
			</section>

			<section class="gut-section gut-about">
				<div class="container gut-about__panel">
					<p class="gut-section__eyebrow">About Mike</p>
					<div class="gut-about__grid">
						<div class="gut-about__copy">
							<h2>Who is the Tech Ninja?</h2>
							<p>
								My name is Mike. By day, I lead the web development, AI, and marketing technology team
								for a digital marketing agency.
							</p>
							<p>
								Mike the Tech Ninja is my side hustle, so I understand what it means to build something
								outside the 9-to-5.
							</p>
						</div>
						<div class="gut-about__card">
							<p>
								I help makers, artists, crafters, and small businesses turn their websites, shops,
								email lists, and marketing into clearer, simpler systems that help people find them,
								buy from them, and come back.
							</p>
						</div>
					</div>
				</div>
			</section>

			<section class="gut-section gut-review">
				<div class="container">
					<div class="gut-section-head">
						<p class="gut-section__eyebrow">What we can look at together</p>
						<h2>Small, practical digital fixes that support how makers actually sell.</h2>
					</div>
					<div class="gut-review-grid gut-review-grid--makers">
						{reviewCards.map(([title, intro, detail]) => (
							<article class="gut-review-card gut-review-card--stacked">
								<h3>{title}</h3>
								<p>{intro}</p>
								<p>{detail}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="gut-section gut-takeaways">
				<div class="container">
					<div class="gut-section-head">
						<p class="gut-section__eyebrow">What you will walk away with</p>
						<h2>In 30 minutes, you will get clear next steps without the agency bloat.</h2>
					</div>
					<div class="gut-takeaway-grid">
						{takeawayCards.map(([title, description]) => (
							<article class="gut-takeaway-card">
								<h3>{title}</h3>
								<p>{description}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="gut-section gut-sellers">
				<div class="container">
					<div class="gut-sellers__header">
						<div>
							<p class="gut-section__eyebrow">Who this is for</p>
							<h2>This is for you if you sell things like:</h2>
						</div>
						<div class="gut-sellers__spotlight">
							<p>
								Whether this is your full-time business, weekend passion, or side hustle, your
								digital presence should help people buy again.
							</p>
						</div>
					</div>
					<div class="gut-seller-grid">
						{sellerItems.map((item) => (
							<article class="gut-seller-card">
								<span>{item}</span>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="gut-section gut-offer">
				<div class="container gut-offer__panel">
					<div class="gut-offer__copy">
						<p class="gut-section__eyebrow">Free 30-minute Digital Gut Check</p>
						<h2>You do not need a corporate office, a giant marketing budget, or a full agency team.</h2>
						<p class="gut-offer__lead">You need a clear next move.</p>
						<p>
							Tell me a little about what you make, where you sell, and what you want to improve. I
							will follow up personally.
						</p>
					</div>
					<div class="gut-offer__card">
						<div class="gut-offer__meta">
							<span>Free 30-minute review</span>
							<span>Personal follow-up</span>
							<span>Practical next steps</span>
						</div>
						<div class="gut-offer__actions">
							<a class="button primary" href="#gut-check-form">Book My Free Digital Gut Check</a>
							<p>No pressure. No bloated proposal. Just practical advice for your creative business.</p>
						</div>
					</div>
				</div>
			</section>
		</main>

		<SiteFooter />
	</div>

	<script src="/scripts/paid-landing.js" defer></script>
</Layout>

<style>
	.landing-shell {
		background:
			radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 24%),
			linear-gradient(180deg, #fff 0%, #f8fafc 100%);
	}

	.landing-topbar {
		position: sticky;
		top: 0;
		z-index: 40;
		border-bottom: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.94);
		backdrop-filter: blur(14px);
	}

	.landing-topbar__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		min-height: 68px;
	}

	.landing-brand {
		display: flex;
		align-items: center;
		gap: 12px;
		font-family: 'Sora', sans-serif;
		font-size: 0.98rem;
		font-weight: 700;
	}

	.landing-brand img {
		width: 38px;
		height: 38px;
		object-fit: contain;
	}

	.landing-topbar__inner .button {
		flex: 0 0 auto;
	}

	.gut-hero {
		position: relative;
		overflow: hidden;
		padding: 56px 0 48px;
	}

	.gut-hero::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(rgba(11, 11, 11, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(11, 11, 11, 0.035) 1px, transparent 1px);
		background-size: 40px 40px;
		mask-image: linear-gradient(135deg, rgba(0, 0, 0, 0.72), transparent 78%);
		opacity: 0.4;
		pointer-events: none;
	}

	.gut-hero__grid {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(340px, 470px);
		gap: 28px;
		align-items: start;
	}

	.gut-eyebrow,
	.gut-section__eyebrow,
	.gut-form-card__eyebrow,
	.gut-success__eyebrow {
		margin: 0 0 14px;
		font-family: 'Sora', sans-serif;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-blue);
	}

	.gut-hero h1 {
		max-width: 11ch;
		font-size: clamp(2.3rem, 4.7vw, 4rem);
		line-height: 1.02;
		letter-spacing: -0.05em;
	}

	.gut-lede {
		max-width: 640px;
		margin-top: 18px;
		font-size: 1.18rem;
		line-height: 1.6;
		color: #475569;
	}

	.gut-hero__support {
		max-width: 640px;
		margin-top: 16px;
		font-size: 1.02rem;
		line-height: 1.7;
	}

	.gut-hero__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 16px;
		margin-top: 28px;
	}

	.gut-trust-line {
		font-size: 0.98rem;
		font-weight: 600;
		color: var(--color-black);
	}

	.gut-audience,
	.gut-offer__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.gut-audience {
		margin-top: 28px;
	}

	.gut-audience span,
	.gut-offer__meta span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 8px 12px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid var(--color-border);
		color: var(--color-black);
		font-size: 0.84rem;
		font-weight: 600;
	}

	.gut-form-card {
		padding: 22px;
		border: 1px solid rgba(37, 99, 235, 0.16);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.95);
		box-shadow: 0 24px 54px rgba(11, 11, 11, 0.08);
		backdrop-filter: blur(18px);
	}

	.gut-form-card h2,
	.gut-section h2 {
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 1.08;
		letter-spacing: -0.04em;
	}

	.gut-form-card p {
		margin-top: 10px;
		font-size: 0.96rem;
		line-height: 1.5;
	}

	.gut-form {
		margin-top: 18px;
	}

	.gut-form__pane {
		display: grid;
		gap: 0;
	}

	.gut-form__pane[hidden] {
		display: none !important;
	}

	.gut-form__grid {
		display: grid;
		gap: 12px;
	}

	.gut-form__grid--two {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.gut-form label {
		display: grid;
		gap: 6px;
		margin: 0 0 12px;
	}

	.gut-form span {
		font-family: 'Sora', sans-serif;
		font-size: 0.86rem;
		font-weight: 600;
		line-height: 1.35;
		color: var(--color-black);
	}

	.gut-form input,
	.gut-form textarea {
		width: 100%;
		padding: 12px 14px;
		border: 1px solid rgba(11, 11, 11, 0.12);
		border-radius: 14px;
		background: rgba(248, 250, 252, 0.9);
		color: var(--color-black);
	}

	.gut-form textarea {
		line-height: 1.5;
	}

	.gut-form input:focus,
	.gut-form textarea:focus {
		outline: 2px solid rgba(37, 99, 235, 0.18);
		border-color: rgba(37, 99, 235, 0.32);
	}

	.gut-form__consent {
		grid-template-columns: auto 1fr;
		align-items: start;
		gap: 10px;
		padding: 14px 16px;
		border: 1px solid rgba(11, 11, 11, 0.1);
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.72);
	}

	.gut-form__consent input {
		width: 18px;
		height: 18px;
		margin-top: 2px;
		padding: 0;
	}

	.gut-form__consent span {
		font-family: 'Source Sans 3', sans-serif;
		font-size: 0.92rem;
		font-weight: 400;
		line-height: 1.45;
		color: #334155;
	}

	.gut-form__consent a {
		color: var(--color-blue);
		text-decoration: underline;
		text-underline-offset: 0.12em;
	}

	.gut-form__actions {
		display: flex;
		justify-content: space-between;
		gap: 12px;
		margin-top: 6px;
	}

	.gut-form__actions .button {
		flex: 1 1 0;
	}

	.gut-form__submit {
		margin-top: 6px;
	}

	.gut-form__note,
	.gut-form__error {
		margin-top: 14px;
		font-size: 0.92rem;
	}

	.gut-form__error {
		color: #b91c1c;
	}

	.gut-success {
		padding: 22px;
		margin-top: 24px;
		border-radius: 18px;
		background: linear-gradient(180deg, rgba(37, 99, 235, 0.08), rgba(163, 230, 53, 0.08));
		border: 1px solid rgba(37, 99, 235, 0.14);
	}

	.gut-success h3 {
		font-size: 1.35rem;
	}

	.gut-success__actions {
		display: flex;
		gap: 12px;
		margin-top: 16px;
	}

	.gut-section {
		padding: 68px 0;
	}

	.gut-section__eyebrow {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 10px;
	}

	.gut-section__eyebrow::after {
		content: '';
		width: 34px;
		height: 2px;
		border-radius: 999px;
		background: linear-gradient(90deg, var(--color-blue), var(--color-green));
	}

	.gut-section-head {
		max-width: 760px;
		margin-bottom: 28px;
	}

	.gut-section__intro,
	.gut-section__body,
	.gut-section__closing {
		font-size: 1.08rem;
		line-height: 1.7;
	}

	.gut-section__body {
		margin-top: 14px;
	}

	.gut-section__closing {
		margin-top: 24px;
		font-weight: 700;
		color: var(--color-black);
	}

	.gut-pain {
		background:
			radial-gradient(circle at 12% 20%, rgba(77, 163, 217, 0.09), transparent 22%),
			linear-gradient(180deg, rgba(245, 245, 243, 0.86), rgba(255, 255, 255, 0.96));
	}

	.gut-pain__grid,
	.gut-about__grid,
	.gut-offer__panel {
		display: grid;
		gap: 24px;
		align-items: start;
	}

	.gut-pain__grid {
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
