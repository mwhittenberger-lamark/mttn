---
const logoSrc = '/mike%20the%20tech%20ninja%20logo%202026.png'

const services = [
	{label: 'Websites & Landing Pages', href: '/services/websites-landing-pages/'},
	{label: 'Custom AI & Automation', href: '/services/custom-ai-automation/'},
	{label: 'Apps & Digital Tools', href: '/services/apps-digital-tools/'},
	{label: 'Paid Media & SEO', href: '/services/paid-media-seo/'},
	{label: 'Lifecycle & Email Marketing', href: '/services/lifecycle-email-marketing/'},
	{label: 'CRO & Digital Strategy', href: '/services/cro-digital-strategy/'},
]

const socialLinks = [
	{
		label: 'Facebook',
		href: 'https://www.facebook.com/mikethetechninja/',
		icon: 'facebook',
	},
	{
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/mike-ninja-413545411',
		icon: 'linkedin',
	},
	{
		label: 'GitHub',
		href: 'https://github.com/mwhittenberger-lamark',
		icon: 'github',
	},
]
---

<footer class="site-footer">
	<div class="container footer-inner">
		<div class="footer-brand">
			<img src={logoSrc} alt="Mike the Tech Ninja logo" />
			<div>
				<div class="footer-title">Mike the Tech Ninja</div>
				<div class="footer-subtitle">Serving the Triangle, NC</div>
				<div class="footer-subtitle">235 Michigan Ave, Cary, NC 27519</div>
			</div>
		</div>
		<div class="footer-socials">
			{socialLinks.map((link) => (
				<a
					href={link.href}
					aria-label={link.label}
					target={link.href.startsWith('http') ? '_blank' : undefined}
					rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
				>
					{link.icon === 'facebook' && (
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path d="M14 8h3V4h-3c-3.31 0-6 2.69-6 6v2H5v4h3v5h4v-5h4l1-4h-5v-2c0-1.1.9-2 2-2z"></path>
						</svg>
					)}
					{link.icon === 'linkedin' && (
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
							<rect x="2" y="9" width="4" height="12"></rect>
							<circle cx="4" cy="4" r="2"></circle>
						</svg>
					)}
					{link.icon === 'github' && (
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
						</svg>
					)}
				</a>
			))}
		</div>
	</div>
	<div class="container footer-services">
		<p>
			{services.map((service, index) => (
				<>
					{index > 0 && <span> / </span>}
					<a href={service.href}>{service.label}</a>
				</>
			))}
		</p>
	</div>
	<div class="container footer-note">
		<p>&copy; 2026 Mike the Tech Ninja. All rights reserved.</p>
		<div class="footer-legal-links">
			<a href="/privacy-policy/">Privacy Policy</a>
			<span>•</span>
			<a href="/terms-of-service/">Terms of Service</a>
		</div>
	</div>
</footer>
